{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  },
  "categories": {
    // HIGH reasoning — deep logical work, complex problem-solving
    "ultrabrain": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    "unspecified-high": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    // MEDIUM reasoning — balanced effort using DeepSeek V4 Pro thinking
    "visual-engineering": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "artistry": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "writing": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    // LOW reasoning — fast tasks using DeepSeek V4 Flash thinking
    "quick": {
      "model": "azure/deepseek-v4-flash",
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "azure/deepseek-v4-flash",
      "reasoningEffort": "low"
    }
  },
  "agents": {
    // HIGH reasoning — orchestration, architecture, planning, deep execution
    "sisyphus": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    "atlas": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    "oracle": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    "prometheus": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    "hephaestus": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    "plan": {
      "model": "azure/gpt-5.5",
      "reasoningEffort": "high"
    },
    // MEDIUM reasoning — validation, building, general work
    "sisyphus-junior": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "OpenCode-Builder": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "build": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "metis": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "momus": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    "multimodal-looker": {
      "model": "azure/deepseek-v4-pro",
      "reasoningEffort": "medium"
    },
    // LOW reasoning — search, lookup, exploration (speed over depth)
    "explore": {
      "model": "azure/deepseek-v4-flash",
      "reasoningEffort": "low",
      "category": "unspecified-low"
    },
    "librarian": {
      "model": "azure/deepseek-v4-flash",
      "reasoningEffort": "low",
      "category": "unspecified-low"
    }
  }
}
