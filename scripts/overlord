#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OVERLORD_DIR="$(dirname "${SCRIPT_DIR}")"
IMAGE_NAME="overlord-opencode"
CONFIG_FILE="${OVERLORD_DIR}/config/opencode.json"

# Container name: one per workspace directory (sanitized for docker)
WORKSPACE_SLUG="$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g')"
CONTAINER_NAME="overlord-${WORKSPACE_SLUG}"

# Zellij session name: just the directory basename (no prefix needed)
ZELLIJ_SESSION="$(basename "$(pwd)")"

# Persistent state directory inside the workspace
OVERLORD_STATE_DIR="$(pwd)/.overlord"

show_help() {
  cat <<'USAGE'
overlord - Launch isolated opencode container

USAGE: overlord <command> [provider]

COMMANDS:
    zellij         Launch zellij terminal multiplexer (default)
    opencode       Launch opencode directly
    shell          Open a zsh shell in the container
    fresh          Remove the container (next launch starts from clean image)
    purge          Remove the container and image (next launch rebuilds everything)
    help           Show this help

PROVIDERS (optional, overrides oh-my-opencode agent models):
    azure          Use azure/gpt-5.3-codex for all agents
    gemini         Use google-vertex/gemini-3.1-pro-preview for all agents

EXAMPLES:
    overlord                         # Launch zellij (default config)
    overlord opencode                # Launch opencode directly
    overlord opencode azure          # Launch opencode with Azure models
    overlord opencode gemini         # Launch opencode with Gemini models
    overlord zellij azure            # Launch zellij with Azure models
    overlord shell                   # Open a shell
    overlord fresh && overlord       # Fresh container, then launch
    overlord purge && overlord       # Full rebuild, then launch
    First run creates a persistent container per workspace directory.
    Subsequent runs reattach to the existing container.
    Anything installed in the container persists across restarts.
    Use 'fresh' to destroy the container and start from a clean image.
    Use 'purge' to also remove the image (full rebuild on next launch).
    .overlord/ inside the workspace and survive fresh/purge.
    Configuration lives in config/opencode.json.
ZELLIJ:
    Ctrl+q         Detach from session (container stays alive)
    Ctrl+b         Tab mode
    Alt+n          New pane
    Alt+[ / Alt+]  Switch panes
USAGE
}

build_image() {
  echo "Building overlord image from ${OVERLORD_DIR}..."
  docker build -t "${IMAGE_NAME}" "${OVERLORD_DIR}"
}

# Backup session data from a running/stopped container before removal.
# If .overlord/opencode-data already has data (volume mount was active),
# docker cp is redundant but harmless.  If the container was created
# without the volume mount, this saves sessions that would otherwise
# be lost on docker rm.
backup_container_data() {
  if ! docker inspect "${CONTAINER_NAME}" &>/dev/null; then
    return
  fi
  mkdir -p "${OVERLORD_STATE_DIR}/opencode-data" "${OVERLORD_STATE_DIR}/zsh-data"
  echo "Backing up session data..."
  docker cp "${CONTAINER_NAME}:/home/overlord/.local/share/opencode/." \
    "${OVERLORD_STATE_DIR}/opencode-data/" 2>/dev/null || true
  docker cp "${CONTAINER_NAME}:/home/overlord/.zsh_data/." \
    "${OVERLORD_STATE_DIR}/zsh-data/" 2>/dev/null || true
}

ensure_image() {
  if ! docker image inspect "${IMAGE_NAME}" &>/dev/null; then
    build_image
  fi
}

container_state() {
  local state
  state=$(docker inspect --format '{{.State.Status}}' "${CONTAINER_NAME}" 2>/dev/null) || true
  echo "${state:-missing}"
}

# --- Parse command ---

COMMAND="${1:-zellij}"
PROVIDER="${2:-}"

# --- Provider → model mapping ---
# Add new providers here: provider_name → "provider/model-id"
resolve_provider_model() {
  case "$1" in
    azure) echo "azure/gpt-5.3-codex" ;;
    gemini) echo "google-vertex/gemini-3.1-pro-preview" ;;
    *)
      echo "Error: unknown provider '$1'" >&2
      echo "Available providers: azure, gemini" >&2
      exit 1
      ;;
  esac
}

if [[ -n "${PROVIDER}" ]]; then
  PROVIDER_MODEL="$(resolve_provider_model "${PROVIDER}")"
  echo "Provider override: all oh-my-opencode agents → ${PROVIDER_MODEL}"
fi

case "${COMMAND}" in
help | -h | --help)
  show_help
  exit 0
  ;;
fresh)
  backup_container_data
  echo "Removing container ${CONTAINER_NAME}..."
  docker stop "${CONTAINER_NAME}" 2>/dev/null || true
  docker rm "${CONTAINER_NAME}" 2>/dev/null || true
  echo "Done. Run 'overlord' to start fresh."
  exit 0
  ;;
purge)
  backup_container_data
  echo "==> Removing container ${CONTAINER_NAME}..."
  docker stop "${CONTAINER_NAME}" 2>/dev/null || true
  docker rm "${CONTAINER_NAME}" 2>/dev/null || true

  echo "==> Removing image ${IMAGE_NAME}..."
  docker rmi "${IMAGE_NAME}" 2>/dev/null || true
  echo "==> Pruning dangling images..."
  docker image prune -f --filter "dangling=true" 2>/dev/null || true
  echo "==> Done. Run 'overlord' to rebuild and launch."
  exit 0
  ;;
opencode | shell | zellij) ;;
*)
  echo "Error: unknown command '${COMMAND}'" >&2
  echo "Run 'overlord help' for usage." >&2
  exit 1
  ;;
esac

# --- Build (if needed) ---

ensure_image

# --- Env vars ---

EXEC_ENV=()

pass_env() {
  local var="$1"
  if [[ -n "${!var:-}" ]]; then
    EXEC_ENV+=(-e "${var}=${!var}")
  fi
}

# Terminal
EXEC_ENV+=(-e "TERM=${TERM:-xterm-256color}")
pass_env COLORTERM
pass_env TERM_PROGRAM
pass_env TERM_PROGRAM_VERSION
pass_env LANG
pass_env LC_ALL

# MCP credentials
pass_env CONTEXT7_API_KEY

# --- LM Studio defaults (host reachable from Docker via host.docker.internal) ---
: "${LMSTUDIO_BASE_URL:=http://host.docker.internal:1234/v1}"
: "${LMSTUDIO_API_KEY:=lm-studio}"
export LMSTUDIO_BASE_URL LMSTUDIO_API_KEY


# --- Normalize Google Cloud / Vertex AI env vars ---
# Users may set any of GOOGLE_CLOUD_LOCATION, VERTEX_LOCATION, etc.
# Normalize to the canonical names that {env:...} templates in opencode.json reference.
: "${GOOGLE_CLOUD_LOCATION:=${VERTEX_LOCATION:-}}"
: "${GOOGLE_CLOUD_PROJECT:=${GCP_PROJECT:-${GCLOUD_PROJECT:-}}}"
export GOOGLE_CLOUD_LOCATION GOOGLE_CLOUD_PROJECT

# --- Provider env vars (update when adding/removing providers in opencode.json) ---
PROVIDER_ENV_VARS=(
  AWS_REGION
  AWS_BEARER_TOKEN_BEDROCK
  GOOGLE_CLOUD_PROJECT
  GOOGLE_CLOUD_LOCATION
  AZURE_RESOURCE_NAME
  AZURE_API_KEY
  LMSTUDIO_BASE_URL
  LMSTUDIO_API_KEY
)
for var in "${PROVIDER_ENV_VARS[@]}"; do
  pass_env "${var}"
done

# Google Cloud ADC — mount credentials file and set container-side path
GCLOUD_ADC="${GOOGLE_APPLICATION_CREDENTIALS:-${HOME}/.config/gcloud/application_default_credentials.json}"
GCLOUD_ADC_HOST=""
if [[ -f "${GCLOUD_ADC}" ]]; then
  GCLOUD_ADC_HOST="${GCLOUD_ADC}"
  EXEC_ENV+=(-e "GOOGLE_APPLICATION_CREDENTIALS=/home/overlord/.config/gcloud/application_default_credentials.json")
fi

# --- Container lifecycle ---

STATE=$(container_state)

ensure_state_dir() {
  mkdir -p "${OVERLORD_STATE_DIR}/opencode-data" "${OVERLORD_STATE_DIR}/zsh-data"
  # Ensure .overlord/ is git-ignored in the workspace
  local gi="$(pwd)/.gitignore"
  if [[ -f "${gi}" ]]; then
    grep -qxF '.overlord/' "${gi}" 2>/dev/null || echo '.overlord/' >>"${gi}"
  else
    echo '.overlord/' >"${gi}"
  fi
}

ensure_running() {
  case "${STATE}" in
  missing)
    echo "Creating container ${CONTAINER_NAME}..."
    ensure_state_dir

    DOCKER_ARGS=(
      -d
      --name "${CONTAINER_NAME}"
      --add-host=host.docker.internal:host-gateway
      --security-opt label=disable
      --security-opt seccomp=unconfined
      -v "$(pwd):/workspace:rw"
      -v /var/run/docker.sock:/var/run/docker.sock
      -v "$(pwd)/.overlord/opencode-data:/home/overlord/.local/share/opencode"
      -v "$(pwd)/.overlord/zsh-data:/home/overlord/.zsh_data"
      "${EXEC_ENV[@]}"
    )

    if [[ -f "${HOME}/.gitconfig" ]]; then
      DOCKER_ARGS+=(-v "${HOME}/.gitconfig:/home/overlord/.gitconfig:ro")
    fi
    if [[ -d "${HOME}/.ssh" ]]; then
      DOCKER_ARGS+=(-v "${HOME}/.ssh:/home/overlord/.ssh:ro")
    fi
    # gcloud ADC is injected after startup (not bind-mounted) so that
    # chown/chmod can fix permissions regardless of host file ownership.

    docker run "${DOCKER_ARGS[@]}" "${IMAGE_NAME}" sleep infinity >/dev/null
    ;;

  exited)
    echo "Starting container ${CONTAINER_NAME}..."
    docker start "${CONTAINER_NAME}" >/dev/null
    ;;

  running) ;;

  *)
    echo "Error: Container ${CONTAINER_NAME} is in unexpected state: ${STATE}" >&2
    echo "Try: overlord fresh" >&2
    exit 1
    ;;
  esac
}

ensure_running

EXEC_USER="overlord"

# --- Fix workspace permissions for rootless Podman ---
# Rootless Podman maps host UID to container UID 0 (root).
# The overlord user (UID 33333) sees mounted files as "others".
# macOS default umask omits the execute bit on directories for
# group/others, which prevents directory traversal inside the
# container. Adding +X (execute on directories only) fixes this.
chmod -R a+X "$(pwd)" 2>/dev/null || true

# --- Inject configs into container ---

cat "${CONFIG_FILE}" |
  docker exec -i "${CONTAINER_NAME}" sh -c 'cat > /home/overlord/.config/opencode/opencode.json'
{
  # Persist forwarded provider env vars so they survive in all container shells
  for var in "${PROVIDER_ENV_VARS[@]}"; do
    if [[ -n "${!var:-}" ]]; then
      printf 'export %s=%q\n' "${var}" "${!var}"
    fi
  done
  # Persist GOOGLE_APPLICATION_CREDENTIALS if gcloud ADC was injected
  if [[ -n "${GCLOUD_ADC_HOST}" ]]; then
    printf 'export GOOGLE_APPLICATION_CREDENTIALS=/home/overlord/.config/gcloud/application_default_credentials.json\n'
  fi
} | docker exec -i "${CONTAINER_NAME}" sh -c 'cat > /home/overlord/.overlord-env'
docker exec "${CONTAINER_NAME}" sh -c \
  'grep -q overlord-env /home/overlord/.zshrc 2>/dev/null || echo "[ -f ~/.overlord-env ] && . ~/.overlord-env" >> /home/overlord/.zshrc'
docker exec "${CONTAINER_NAME}" sh -c \
  'grep -q zsh_data /home/overlord/.zshrc 2>/dev/null || echo "export HISTFILE=~/.zsh_data/.zsh_history" >> /home/overlord/.zshrc'

if [[ -n "${PROVIDER:-}" ]]; then
  # Replace all "model" values in oh-my-opencode config with the provider model
  sed 's|"model": ".*"|"model": "'"${PROVIDER_MODEL}"'"|g' "${OVERLORD_DIR}/config/oh-my-opencode.jsonc" |
    docker exec -i "${CONTAINER_NAME}" sh -c 'cat > /home/overlord/.config/opencode/oh-my-opencode.jsonc'
else
  cat "${OVERLORD_DIR}/config/oh-my-opencode.jsonc" |
    docker exec -i "${CONTAINER_NAME}" sh -c 'cat > /home/overlord/.config/opencode/oh-my-opencode.jsonc'
fi

# Inject gcloud ADC credentials (copied, not bind-mounted, so permissions can be fixed)
if [[ -n "${GCLOUD_ADC_HOST}" ]]; then
  docker exec "${CONTAINER_NAME}" sh -c 'mkdir -p /home/overlord/.config/gcloud'
  cat "${GCLOUD_ADC_HOST}" |
    docker exec -i "${CONTAINER_NAME}" sh -c 'cat > /home/overlord/.config/gcloud/application_default_credentials.json'
fi

cat "${OVERLORD_DIR}/config/zellij-config.kdl" |
  docker exec -i "${CONTAINER_NAME}" sh -c 'cat > /home/overlord/.config/zellij/config.kdl'

# --- Fix permissions (single pass for all injected configs + volumes) ---
# chown sets ownership; chmod a+rwX is the fallback for rootless Podman
# where UID namespace mapping makes chown ineffective.
docker exec "${CONTAINER_NAME}" sh -c '
    chmod 755 /home/overlord
    chown -R overlord:overlord \
        /home/overlord/.config \
        /home/overlord/.oh-my-zsh \
        /home/overlord/.overlord-env \
        /home/overlord/.zshrc \
        /home/overlord/.cache \
        /home/overlord/.local/share/opencode \
        /home/overlord/.zsh_data \
        2>/dev/null || true
    chmod -R a+rwX \
        /home/overlord/.local \
        /home/overlord/.zsh_data \
        /home/overlord/.cache \
        2>/dev/null || true
'

# --- Fix cross-platform native modules ---
docker exec -u "${EXEC_USER}" "${CONTAINER_NAME}" bash -c '
    if [ -d /workspace/node_modules ] && [ -f /workspace/package.json ]; then
        MARKER=/workspace/node_modules/.overlord-platform
        CURRENT="linux-$(uname -m)"
        if [ ! -f "$MARKER" ] || [ "$(cat "$MARKER" 2>/dev/null)" != "$CURRENT" ]; then
            echo "==> Fixing native dependencies for ${CURRENT}..."
            cd /workspace && npm install --no-audit --no-fund 2>&1 | tail -5
            echo "$CURRENT" > "$MARKER"
            echo "==> Done."
        fi
    fi
'

# --- Ensure zellij cache dir is writable (rootless Podman UID mapping can break chown) ---
docker exec "${CONTAINER_NAME}" sh -c \
  'mkdir -p /home/overlord/.cache/zellij && chown -R overlord:overlord /home/overlord/.cache/zellij; chmod -R a+rwX /home/overlord/.cache'

# --- Launch ---
case "${COMMAND}" in
opencode)
  docker exec -it -w /workspace -u "${EXEC_USER}" "${EXEC_ENV[@]}" "${CONTAINER_NAME}" \
    opencode
  ;;
shell)
  docker exec -it -w /workspace -u "${EXEC_USER}" "${EXEC_ENV[@]}" "${CONTAINER_NAME}" \
    zsh -il
  ;;
zellij)
  docker exec -it -u "${EXEC_USER}" "${EXEC_ENV[@]}" "${CONTAINER_NAME}" \
    zellij attach "${ZELLIJ_SESSION}" --create
  ;;
esac
