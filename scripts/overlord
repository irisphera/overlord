#!/usr/bin/env bash
set -euo pipefail

RESOLVED_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${RESOLVED_SCRIPT}")" && pwd)"
OVERLORD_DIR="$(dirname "${SCRIPT_DIR}")"
OPENCODE_CONFIG_NAME="opencode.json"
DEFAULT_OH_MY_CONFIG_NAME="oh-my-openagent.jsonc"
OPENCODE_CONFIG_SCHEMA='"$schema":"https://opencode.ai/config.json"'
OH_MY_CONFIG_SCHEMA="\"\$schema\": \"https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json\""
OPENCODE_REQUIRED_VERSION="latest"
OH_MY_OPENAGENT_REQUIRED_VERSION="latest"
OH_MY_OPENAGENT_PACKAGE="oh-my-openagent@${OH_MY_OPENAGENT_REQUIRED_VERSION}"
OH_MY_OPENAGENT_CACHE_DIR="/home/overlord/.cache/opencode/packages/${OH_MY_OPENAGENT_PACKAGE}"
OH_MY_OPENAGENT_BIN="/home/overlord/.local/bin/oh-my-openagent"
OPENCODE_WEB_HOSTNAME="0.0.0.0"
OPENCODE_WEB_PORT="4090"
OPENCODE_WEB_PID_FILE="/home/overlord/.local/share/opencode/overlord-serve.pid"
OPENCODE_WEB_LOG_FILE="/home/overlord/.local/share/opencode/overlord-serve.log"
OPENCODE_STRUCTURED_LOG_DIR="/home/overlord/.local/share/opencode/log"
OPENCODE_WEB_WAIT_SECONDS=90
OPENCODE_HOST_PROXY_BIND_HOST="0.0.0.0"
CONTAINER_HOME="/home/overlord"
RUNTIME_CONFIG_DIR="/home/overlord/.config"
RUNTIME_OPENCODE_CONFIG_DIR="${RUNTIME_CONFIG_DIR}/opencode"
RUNTIME_OPENCODE_CONFIG_FILE="${RUNTIME_OPENCODE_CONFIG_DIR}/opencode.json"
RUNTIME_OH_MY_OPENCODE_CONFIG_FILE="${RUNTIME_OPENCODE_CONFIG_DIR}/oh-my-opencode.jsonc"
RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE="${RUNTIME_OPENCODE_CONFIG_DIR}/oh-my-openagent.jsonc"
RUNTIME_ZELLIJ_CONFIG_DIR="${RUNTIME_CONFIG_DIR}/zellij"
RUNTIME_ZELLIJ_CONFIG_FILE="${RUNTIME_ZELLIJ_CONFIG_DIR}/config.kdl"
RUNTIME_GCLOUD_CONFIG_DIR="${RUNTIME_CONFIG_DIR}/gcloud"
RUNTIME_GCLOUD_ADC_FILE="${RUNTIME_GCLOUD_CONFIG_DIR}/application_default_credentials.json"

# Detect container engine (podman preferred, docker fallback)
if command -v podman &>/dev/null; then
	ENGINE=podman
elif command -v docker &>/dev/null; then
	ENGINE=docker
else
	echo "Error: neither podman nor docker found in PATH" >&2
	exit 1
fi

# Container/image identity: one per workspace directory (sanitized for container/image names)
WORKSPACE_SLUG="$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g')"
IMAGE_NAME="overlord-opencode-${WORKSPACE_SLUG}"
CONTAINER_NAME="overlord-${WORKSPACE_SLUG}"

# Zellij session name: just the directory basename (no prefix needed)
ZELLIJ_SESSION="$(basename "$(pwd)")"

# Persistent state directory inside the workspace
OVERLORD_STATE_DIR="$(pwd)/.overlord"
OPENCODE_HOST_PROXY_SCRIPT="${OVERLORD_STATE_DIR}/opencode-web-proxy.cjs"
OPENCODE_HOST_PROXY_PID_FILE="${OVERLORD_STATE_DIR}/opencode-web-proxy.pid"
OPENCODE_HOST_PROXY_PORT_FILE="${OVERLORD_STATE_DIR}/opencode-web-proxy.port"
OPENCODE_HOST_PROXY_LOG_FILE="${OVERLORD_STATE_DIR}/opencode-web-proxy.log"

show_help() {
	cat <<'USAGE'
overlord - Launch isolated OpenCode workspace container

USAGE: overlord [--list-configs | --config PRESET | --lms-model MODEL] [command]

OPTIONS:
	--list-configs     List available oh-my-openagent routing presets
	--config PRESET    Use an oh-my-openagent routing preset with config/opencode.json
	--lms-model MODEL  Rewrite all oh-my-openagent routes to lmstudio/MODEL

COMMANDS:
    web            Start/reuse OpenCode web mode and print local/network URLs (default)
    opencode       Alias for 'web'
    shell          Open a zsh shell in the container
    zellij         Launch zellij terminal multiplexer explicitly
    fresh          Remove the container (next launch starts from clean image)
    purge          Remove the container and image (next launch rebuilds everything)
    help           Show this help

EXAMPLES:
	    overlord --list-configs          # List available agent routing presets
	    overlord                         # Start/reuse the OpenCode web UI (default config)
	    overlord --config default        # Use config/oh-my-openagent.jsonc
	AZURE_API_KEY=... AZURE_RESOURCE_NAME=... overlord  # Start web UI with the default Azure routing
    overlord web                     # Start/reuse the OpenCode web UI explicitly
    overlord opencode                # Alias for 'overlord web'
	    overlord --config pro                   # Use config/oh-my-openagent.pro.jsonc
	    overlord --config gemini                # Use config/oh-my-openagent.gemini.jsonc
	    overlord --config opus                  # Use config/oh-my-openagent.opus.jsonc
	    overlord --config m3                    # Use OpenCode Zen MiniMax M3 routing
	    overlord --lms-model qwen3-8b web       # Use LM Studio with an explicit runtime model
	    overlord --lms-model qwen3-8b zellij    # Same runtime model, with zellij
    overlord shell                   # Open a shell
    overlord fresh && overlord       # Fresh container, then launch
    overlord purge && overlord       # Full rebuild, then launch
    First run creates a persistent container per workspace directory.
    Subsequent runs reuse the existing container and web server.
    Anything installed in the container persists across restarts.
    Workspace /workspace/setup-devcontainer.sh runs automatically during fresh/restarted setup.
    Use 'fresh' to destroy the container and start from a clean image.
    Use 'purge' to also remove the image (full rebuild on next launch).
    .overlord/ inside the workspace and survive fresh/purge.
    Configuration lives in config/opencode.json by default.
ZELLIJ:
    Ctrl+q         Detach from session (container stays alive)
    Ctrl+b         Tab mode
    Alt+n          New pane
    Alt+[ / Alt+]  Switch panes
USAGE
}

build_image() {
	echo "Building overlord image from ${OVERLORD_DIR}..."
	"${ENGINE}" build -t "${IMAGE_NAME}" "${OVERLORD_DIR}"
}

# Backup session data from a running/stopped container before removal.
# If .overlord/opencode-data already has data (volume mount was active),
# Container cp is redundant but harmless.  If the container was created
# without the volume mount, this saves sessions that would otherwise
# be lost on container rm.
backup_container_data() {
	if ! "${ENGINE}" inspect "${CONTAINER_NAME}" &>/dev/null; then
		return
	fi
	mkdir -p "${OVERLORD_STATE_DIR}/opencode-data" "${OVERLORD_STATE_DIR}/zsh-data"
	echo "Backing up session data..."
	"${ENGINE}" cp "${CONTAINER_NAME}:/home/overlord/.local/share/opencode/." \
		"${OVERLORD_STATE_DIR}/opencode-data/" 2>/dev/null || true
	"${ENGINE}" cp "${CONTAINER_NAME}:/home/overlord/.zsh_data/." \
		"${OVERLORD_STATE_DIR}/zsh-data/" 2>/dev/null || true
}

clear_persisted_opencode_server_state() {
	mkdir -p "${OVERLORD_STATE_DIR}/opencode-data"
	rm -f \
		"${OVERLORD_STATE_DIR}/opencode-data/$(basename "${OPENCODE_WEB_PID_FILE}")" \
		"${OVERLORD_STATE_DIR}/opencode-data/$(basename "${OPENCODE_WEB_LOG_FILE}")"
}

ensure_image() {
	if ! "${ENGINE}" image inspect "${IMAGE_NAME}" &>/dev/null; then
		build_image
	fi
}

container_state() {
	local state
	state=$("${ENGINE}" inspect --format '{{.State.Status}}' "${CONTAINER_NAME}" 2>/dev/null) || true
	echo "${state:-missing}"
}

resolve_published_web_port() {
	local published
	local line

	published=$("${ENGINE}" port "${CONTAINER_NAME}" "${OPENCODE_WEB_PORT}/tcp" 2>/dev/null || true)
	if [[ -z "${published}" ]]; then
		echo "Error: container ${CONTAINER_NAME} does not publish OpenCode web port ${OPENCODE_WEB_PORT}/tcp." >&2
		echo "This container predates web-first launcher support. Run 'overlord fresh' once, then retry." >&2
		exit 1
	fi

	while IFS= read -r line; do
		if [[ "${line}" =~ :([0-9]+)$ ]]; then
			printf '%s\n' "${BASH_REMATCH[1]}"
			return 0
		fi
	done <<<"${published}"

	echo "Error: could not resolve the published host port for ${CONTAINER_NAME}." >&2
	echo "Run 'overlord fresh' once, then retry." >&2
	exit 1
}

resolve_network_host_ip() {
	if ! command -v python3 >/dev/null 2>&1; then
		return 0
	fi

	python3 - <<'PY'
import socket

s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
try:
    s.connect(("8.8.8.8", 80))
    ip = s.getsockname()[0]
    if ip and not ip.startswith("127."):
        print(ip)
except OSError:
    pass
finally:
    s.close()
PY
}

wait_for_opencode_web() {
	local host_port="$1"
	local health_url="http://127.0.0.1:${host_port}/global/health"
	local curl_args=(--silent --fail --max-time 5)
	local attempt

	if [[ -n "${OPENCODE_SERVER_PASSWORD:-}" ]]; then
		curl_args+=(-u "opencode:${OPENCODE_SERVER_PASSWORD}")
	fi

	for ((attempt = 1; attempt <= OPENCODE_WEB_WAIT_SECONDS; attempt += 1)); do
		if curl "${curl_args[@]}" "${health_url}" >/dev/null; then
			return 0
		fi
		sleep 1
	done

	echo "Error: OpenCode web UI did not become healthy at ${health_url}" >&2
	echo "Check ${OPENCODE_WEB_LOG_FILE} inside ${CONTAINER_NAME} for startup errors." >&2
	exit 1
}

wait_for_opencode_web_ui() {
	local host_port="$1"
	local root_url="http://127.0.0.1:${host_port}/"
	local curl_args=(--silent --fail --max-time 10)
	local attempt
	local response

	if [[ -n "${OPENCODE_SERVER_PASSWORD:-}" ]]; then
		curl_args+=(-u "opencode:${OPENCODE_SERVER_PASSWORD}")
	fi

	for ((attempt = 1; attempt <= OPENCODE_WEB_WAIT_SECONDS; attempt += 1)); do
		response=$(curl "${curl_args[@]}" "${root_url}" 2>/dev/null || true)
		if [[ "${response}" == *"<!doctype html>"* ]]; then
			return 0
		fi
		sleep 1
	done

	echo "Error: OpenCode web UI root did not become ready at ${root_url}" >&2
	echo "Check ${OPENCODE_WEB_LOG_FILE} inside ${CONTAINER_NAME} for startup errors." >&2
	exit 1
}

verify_oh_my_openagent_loaded() {
	local attempt
	local status

	for ((attempt = 1; attempt <= OPENCODE_WEB_WAIT_SECONDS; attempt += 1)); do
		if "${ENGINE}" exec -i "${CONTAINER_NAME}" sh -s -- \
			"${OPENCODE_WEB_LOG_FILE}" \
			"${OPENCODE_STRUCTURED_LOG_DIR}" \
			"${OPENCODE_WEB_PORT}" <<'EOF'
log_file="$1"
log_dir="$2"
port="$3"
success_line="service=plugin path=oh-my-openagent@latest loading plugin"
failure_pattern='service=plugin .*oh-my-openagent.*(failed|incompatible|no server entrypoint)'
lsp_enabled_pattern='service=lsp .* enabled LSP servers'
lsp_disabled_pattern='service=lsp all LSPs are disabled'

has_log_pattern() {
	pattern="$1"
	if [ -d "${log_dir}" ] && grep -R -E "${pattern}" "${log_dir}" >/dev/null 2>&1; then
		return 0
	fi
	if [ -f "${log_file}" ] && grep -E "${pattern}" "${log_file}" >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

if [ -n "${OPENCODE_SERVER_PASSWORD:-}" ]; then
	curl --silent --fail --max-time 5 \
		-u "opencode:${OPENCODE_SERVER_PASSWORD}" \
		-H "x-opencode-directory: /workspace" \
		"http://127.0.0.1:${port}/path?directory=/workspace" >/dev/null 2>&1 || true
else
	curl --silent --fail --max-time 5 \
		-H "x-opencode-directory: /workspace" \
		"http://127.0.0.1:${port}/path?directory=/workspace" >/dev/null 2>&1 || true
fi

if has_log_pattern "${failure_pattern}"; then
	exit 2
fi

if has_log_pattern "$(printf '%s' "${success_line}" | sed 's/[][(){}.^$*+?|\\]/\\&/g')"; then
	if has_log_pattern "${lsp_enabled_pattern}"; then
		exit 0
	fi
	if has_log_pattern "${lsp_disabled_pattern}"; then
		exit 3
	fi
fi
exit 1
EOF
		then
			return 0
		fi
		status=$?
		if [[ "${status}" -eq 2 || "${status}" -eq 3 ]]; then
			break
		fi
		sleep 1
	done

	echo "Error: OpenCode web started, but oh-my-openagent did not load with native LSP enabled." >&2
	echo "Expected plugin load plus 'enabled LSP servers' in ${OPENCODE_STRUCTURED_LOG_DIR}/*.log or ${OPENCODE_WEB_LOG_FILE}." >&2
	echo "Relevant OpenCode log lines:" >&2
	"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -s -- \
		"${OPENCODE_WEB_LOG_FILE}" \
		"${OPENCODE_STRUCTURED_LOG_DIR}" <<'EOF' >&2 || true
log_file="$1"
log_dir="$2"
pattern='oh-my-openagent|oh-my-opencode|service=plugin|service=mcp|service=lsp|key=(websearch|context7|grep_app|lsp|ast_grep)|plugin|failed|error|cannot find|not found|config path=|path='
if [ -d "${log_dir}" ]; then
	grep -R -Ei "${pattern}" "${log_dir}" 2>/dev/null | tail -120 || true
fi
if [ -f "${log_file}" ]; then
	grep -Ei "${pattern}" "${log_file}" 2>/dev/null | tail -120 || true
else
	echo "${log_file} does not exist"
fi
EOF
	exit 1
}

write_host_web_proxy_script() {
	cat >"${OPENCODE_HOST_PROXY_SCRIPT}" <<'EOF'
const fs = require("fs")
const http = require("http")
const net = require("net")

const upstreamPort = Number(process.argv[2])
const bindHost = process.argv[3]
const portFile = process.argv[4]
const upstreamHost = "127.0.0.1"

const proxyHeaders = (headers, { upgrade = false } = {}) => {
  const result = { ...headers, host: `${upstreamHost}:${upstreamPort}` }
  if (upgrade) {
    result.connection = headers.connection || "Upgrade"
  } else {
    result.connection = "close"
  }
  return result
}

const server = http.createServer((req, res) => {
  const upstream = http.request(
    {
      host: upstreamHost,
      port: upstreamPort,
      path: req.url,
      method: req.method,
      headers: proxyHeaders(req.headers),
      agent: false,
    },
    (upstreamRes) => {
      const headers = { ...upstreamRes.headers }
      delete headers.connection
      delete headers["keep-alive"]
      res.writeHead(upstreamRes.statusCode || 502, headers)
      upstreamRes.pipe(res)
    },
  )

  upstream.on("error", (error) => {
    res.statusCode = 502
    res.end(String(error))
  })

  req.pipe(upstream)
})

server.on("upgrade", (req, socket, head) => {
  const upstream = net.connect({ host: upstreamHost, port: upstreamPort }, () => {
    const lines = [`${req.method} ${req.url} HTTP/${req.httpVersion}`]
    const headers = proxyHeaders(req.headers, { upgrade: true })
    for (const [name, value] of Object.entries(headers)) {
      if (Array.isArray(value)) {
        for (const item of value) lines.push(`${name}: ${item}`)
      } else if (value !== undefined) {
        lines.push(`${name}: ${value}`)
      }
    }
    upstream.write(`${lines.join("\r\n")}\r\n\r\n`)
    if (head.length > 0) upstream.write(head)
    socket.pipe(upstream).pipe(socket)
  })

  upstream.on("error", () => socket.destroy())
  socket.on("error", () => upstream.destroy())
})

server.listen(0, bindHost, () => {
  fs.writeFileSync(portFile, String(server.address().port))
})
EOF
}

wait_for_host_web_proxy() {
	local proxy_port
	local attempt

	for ((attempt = 1; attempt <= OPENCODE_WEB_WAIT_SECONDS; attempt += 1)); do
		if [[ -s "${OPENCODE_HOST_PROXY_PORT_FILE}" ]]; then
			proxy_port=$(<"${OPENCODE_HOST_PROXY_PORT_FILE}")
		if curl --silent --fail --max-time 10 "http://localhost:${proxy_port}/" | grep -q '<!doctype html>'; then
			printf '%s\n' "${proxy_port}"
			return 0
		fi
		fi
		sleep 1
	done

		echo "Error: local OpenCode host proxy did not become healthy." >&2
		echo "Check ${OPENCODE_HOST_PROXY_LOG_FILE} for proxy startup errors." >&2
		return 1
}

ensure_host_web_proxy() {
	local upstream_port="$1"
	local proxy_pid=""
	local proxy_port

	if ! command -v node >/dev/null 2>&1; then
		echo "Error: node is required on the host to proxy OpenCode web traffic from Podman." >&2
		return 1
	fi

	ensure_state_dir
	write_host_web_proxy_script

	if [[ -s "${OPENCODE_HOST_PROXY_PID_FILE}" ]]; then
		proxy_pid=$(<"${OPENCODE_HOST_PROXY_PID_FILE}")
		if [[ -n "${proxy_pid}" ]] && kill -0 "${proxy_pid}" 2>/dev/null; then
			kill "${proxy_pid}" 2>/dev/null || true
		fi
	fi

	rm -f "${OPENCODE_HOST_PROXY_PORT_FILE}"
	nohup node "${OPENCODE_HOST_PROXY_SCRIPT}" "${upstream_port}" "${OPENCODE_HOST_PROXY_BIND_HOST}" "${OPENCODE_HOST_PROXY_PORT_FILE}" >"${OPENCODE_HOST_PROXY_LOG_FILE}" 2>&1 &
	echo $! >"${OPENCODE_HOST_PROXY_PID_FILE}"

	proxy_port="$(wait_for_host_web_proxy)" || return 1
	printf '%s\n' "${proxy_port}"
}

stop_host_web_proxy() {
	local proxy_pid=""

	if [[ -s "${OPENCODE_HOST_PROXY_PID_FILE}" ]]; then
		proxy_pid=$(<"${OPENCODE_HOST_PROXY_PID_FILE}")
		if [[ -n "${proxy_pid}" ]] && kill -0 "${proxy_pid}" 2>/dev/null; then
			kill "${proxy_pid}" 2>/dev/null || true
		fi
	fi

	rm -f "${OPENCODE_HOST_PROXY_PID_FILE}" "${OPENCODE_HOST_PROXY_PORT_FILE}"
}

ensure_opencode_web_server() {
	local host_port
	local access_port
	local network_ip

	ensure_opencode_runtime_version
	restart_opencode_web_if_needed
	host_port="$(resolve_published_web_port)"

	echo "Ensuring OpenCode web server is running in ${CONTAINER_NAME}..."
	"${ENGINE}" exec -i -w /workspace -u "${EXEC_USER}" "${EXEC_ENV[@]}" "${CONTAINER_NAME}" \
		sh -s -- "${OPENCODE_WEB_PID_FILE}" "${OPENCODE_WEB_LOG_FILE}" "${OPENCODE_WEB_HOSTNAME}" "${OPENCODE_WEB_PORT}" <<'EOF'
PID_FILE="$1"
LOG_FILE="$2"
HOST="$3"
PORT="$4"

if [ -s "${PID_FILE}" ]; then
  PID=$(cat "${PID_FILE}" 2>/dev/null || true)
  if [ -n "${PID}" ] && kill -0 "${PID}" 2>/dev/null && [ -r "/proc/${PID}/cmdline" ]; then
    CMDLINE=$(tr '\000' ' ' < "/proc/${PID}/cmdline")
    case "${CMDLINE}" in
	  *"opencode web --hostname ${HOST} --port ${PORT}"*)
        exit 0
        ;;
      *"opencode web --pure --hostname ${HOST} --port ${PORT}"*|\
      *"opencode serve --hostname ${HOST} --port ${PORT}"*)
        kill "${PID}" 2>/dev/null || true
        for _ in 1 2 3 4 5; do
          if ! kill -0 "${PID}" 2>/dev/null; then
            break
          fi
          sleep 1
        done
        ;;
    esac
  fi
  rm -f "${PID_FILE}"
fi

	mkdir -p "$(dirname "${PID_FILE}")"
nohup opencode web --hostname "${HOST}" --port "${PORT}" >"${LOG_FILE}" 2>&1 &
echo $! >"${PID_FILE}"
EOF

	wait_for_opencode_web "${host_port}"
	wait_for_opencode_web_ui "${host_port}"
	verify_oh_my_openagent_loaded
	access_port="${host_port}"
	if [[ "${ENGINE}" == "podman" ]]; then
		access_port="$(ensure_host_web_proxy "${host_port}")" || return 1
	fi
	if [[ "${access_port}" != "${host_port}" ]]; then
		printf 'Published port: http://localhost:%s\n' "${host_port}"
	fi
	printf 'Local access:   http://localhost:%s\n' "${access_port}"
	network_ip="$(resolve_network_host_ip)"
	if [[ -n "${network_ip}" ]]; then
		if [[ "${access_port}" != "${host_port}" ]]; then
			printf 'Published LAN:  http://%s:%s\n' "${network_ip}" "${host_port}"
		fi
		printf 'Network access: http://%s:%s\n' "${network_ip}" "${access_port}"
	fi
}

ensure_opencode_runtime_version() {
	local current_version
	local installed_version
	local latest_version

	current_version=$("${ENGINE}" exec -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" node -p \
		"require('/home/overlord/.bun/install/global/node_modules/opencode-ai/package.json').version" 2>/dev/null || true)
	if [[ -z "${current_version}" ]]; then
		current_version=$("${ENGINE}" exec -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" opencode --version 2>/dev/null || true)
	fi
	if [[ "${OPENCODE_REQUIRED_VERSION}" == "latest" ]]; then
		latest_version=$("${ENGINE}" exec -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" npm view opencode-ai version 2>/dev/null || true)
		if [[ -n "${latest_version}" && "${current_version}" == "${latest_version}" ]]; then
			return 0
		fi
		if [[ -z "${latest_version}" && -n "${current_version}" ]]; then
			return 0
		fi
	elif [[ "${current_version}" == "${OPENCODE_REQUIRED_VERSION}" ]]; then
		return 0
	fi

	echo "Ensuring OpenCode CLI package opencode-ai@${OPENCODE_REQUIRED_VERSION} in ${CONTAINER_NAME}..."
	"${ENGINE}" exec -i -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" sh -s -- "${OPENCODE_REQUIRED_VERSION}" <<'EOF'
set -e

required_version="$1"
install_log="$(mktemp)"
bun_bin="/usr/local/bin/bun"

if [ ! -x "${bun_bin}" ]; then
	bun_bin="bun"
fi

cleanup() {
	rm -f "${install_log}"
}

trap cleanup EXIT

if ! "${bun_bin}" add -g "opencode-ai@${required_version}" >"${install_log}" 2>&1; then
	cat "${install_log}" >&2
	exit 1
fi
EOF
	installed_version=$("${ENGINE}" exec -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" node -p \
		"require('/home/overlord/.bun/install/global/node_modules/opencode-ai/package.json').version" 2>/dev/null || true)
	if [[ -z "${installed_version}" ]]; then
		installed_version=$("${ENGINE}" exec -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" opencode --version 2>/dev/null || true)
	fi
	printf 'OpenCode CLI version: %s\n' "${installed_version:-unknown}"
	OPENCODE_WEB_RESTART_REQUIRED=1
}

ensure_oh_my_openagent_runtime_package() {
	local installed_version

	if "${ENGINE}" exec -i -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" sh -s -- \
		"${OH_MY_OPENAGENT_REQUIRED_VERSION}" \
		"${OH_MY_OPENAGENT_CACHE_DIR}" \
		"${OH_MY_OPENAGENT_BIN}" <<'EOF'
set -e

required_version="$1"
cache_dir="$2"
public_bin="$3"
package_dir="${cache_dir}/node_modules/oh-my-openagent"
package_json="${package_dir}/package.json"
canonical_bin="${cache_dir}/node_modules/.bin/oh-my-openagent"
fallback_bin="${package_dir}/bin/oh-my-opencode.js"

if [ ! -f "${package_json}" ] || [ ! -x "${public_bin}" ]; then
	exit 1
fi

installed_version="$(node -p "require('${package_json}').version" 2>/dev/null || true)"
if [ "${required_version}" = "latest" ]; then
	latest_version="$(npm view oh-my-openagent version 2>/dev/null || true)"
	if [ -n "${latest_version}" ]; then
		test "${installed_version}" = "${latest_version}"
	else
		test -n "${installed_version}"
	fi
else
	test "${installed_version}" = "${required_version}"
fi
EOF
	then
		return 0
	fi

	echo "Ensuring OpenCode plugin package ${OH_MY_OPENAGENT_PACKAGE} in ${CONTAINER_NAME}..."
	"${ENGINE}" exec -i -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" sh -s -- \
		"${OH_MY_OPENAGENT_PACKAGE}" \
		"${OH_MY_OPENAGENT_CACHE_DIR}" \
		"${OH_MY_OPENAGENT_BIN}" <<'EOF'
set -e

package_spec="$1"
cache_dir="$2"
public_bin="$3"
package_dir="${cache_dir}/node_modules/oh-my-openagent"
package_json="${package_dir}/package.json"
canonical_bin="${cache_dir}/node_modules/.bin/oh-my-openagent"
fallback_bin="${package_dir}/bin/oh-my-opencode.js"
install_log="$(mktemp)"
bun_bin="/usr/local/bin/bun"

if [ ! -x "${bun_bin}" ]; then
	bun_bin="bun"
fi

cleanup() {
	rm -f "${install_log}"
}

trap cleanup EXIT

mkdir -p "${cache_dir}" "$(dirname "${public_bin}")"
cd "${cache_dir}"

if [ ! -f package.json ]; then
	"${bun_bin}" init -y >/dev/null 2>&1
fi

if ! "${bun_bin}" add "${package_spec}" >"${install_log}" 2>&1; then
	cat "${install_log}" >&2
	exit 1
fi

if [ -x "${canonical_bin}" ]; then
	ln -sf "${canonical_bin}" "${public_bin}"
elif [ -x "${fallback_bin}" ]; then
	ln -sf "${fallback_bin}" "${public_bin}"
else
	echo "Error: ${package_spec} installed without an executable oh-my-openagent entrypoint" >&2
	exit 1
fi

test -x "${public_bin}"
EOF
	installed_version=$("${ENGINE}" exec -u "${EXEC_USER}" "${CONTAINER_NAME}" env -i "${PACKAGE_ENV[@]}" node -p \
		"require('${OH_MY_OPENAGENT_CACHE_DIR}/node_modules/oh-my-openagent/package.json').version" 2>/dev/null || true)
	printf 'oh-my-openagent version: %s\n' "${installed_version:-unknown}"
	OPENCODE_WEB_RESTART_REQUIRED=1
}

ensure_oh_my_openagent_runtime_config() {
	local repaired=0

	if ! "${ENGINE}" exec -i "${CONTAINER_NAME}" sh -s -- \
		"${RUNTIME_OPENCODE_CONFIG_FILE}" <<'EOF'
set -e

config_file="$1"
test -f "${config_file}" && grep -Fq 'oh-my-openagent' "${config_file}"
EOF
	then
		echo "Ensuring OpenCode plugin config includes ${OH_MY_OPENAGENT_PACKAGE} in ${CONTAINER_NAME}..."
		"${ENGINE}" exec "${CONTAINER_NAME}" sh -c "mkdir -p ${RUNTIME_OPENCODE_CONFIG_DIR}"
		if ! "${ENGINE}" exec "${CONTAINER_NAME}" test -f "${RUNTIME_OPENCODE_CONFIG_FILE}"; then
			if [[ -n "${LMS_MODEL}" ]]; then
				sed -e 's/"lm-studio"/"'"${LMS_MODEL}"'"/g' \
					-e 's/"LM Studio (Local)"/"'"${LMS_MODEL}"'"/g' \
					"${CONFIG_FILE}" |
					"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -c 'cat > '"${RUNTIME_OPENCODE_CONFIG_FILE}"
			else
				"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -c 'cat > '"${RUNTIME_OPENCODE_CONFIG_FILE}" <"${CONFIG_FILE}"
			fi
		else
			"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -s -- \
				"${RUNTIME_OPENCODE_CONFIG_FILE}" \
				"${OH_MY_OPENAGENT_PACKAGE}" <<'EOF'
set -e

config_file="$1"
package_spec="$2"
tmp_file="$(mktemp)"

cleanup() {
	rm -f "${tmp_file}"
}

trap cleanup EXIT

jq --arg plugin "${package_spec}" '
  .plugin = ((.plugin // []) | if index($plugin) then . else . + [$plugin] end)
' "${config_file}" >"${tmp_file}"
cat "${tmp_file}" >"${config_file}"
EOF
		fi
		repaired=1
	fi

	if ! "${ENGINE}" exec "${CONTAINER_NAME}" test -f "${RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE}"; then
		echo "Ensuring oh-my-openagent routing config in ${CONTAINER_NAME}..."
		if [[ -n "${MODEL_OVERRIDE}" ]]; then
			sed 's|"model": ".*"|"model": "'"${MODEL_OVERRIDE}"'"|g' "${OH_MY_CONFIG_FILE}" |
				"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -c 'cat > '"${RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE}"
		else
			"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -c 'cat > '"${RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE}" <"${OH_MY_CONFIG_FILE}"
		fi
		repaired=1
	fi

	if ! "${ENGINE}" exec "${CONTAINER_NAME}" test -f "${RUNTIME_OH_MY_OPENCODE_CONFIG_FILE}"; then
		if [[ -n "${MODEL_OVERRIDE}" ]]; then
			sed 's|"model": ".*"|"model": "'"${MODEL_OVERRIDE}"'"|g' "${OH_MY_CONFIG_FILE}" |
				"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -c 'cat > '"${RUNTIME_OH_MY_OPENCODE_CONFIG_FILE}"
		else
			"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -c 'cat > '"${RUNTIME_OH_MY_OPENCODE_CONFIG_FILE}" <"${OH_MY_CONFIG_FILE}"
		fi
		repaired=1
	fi

	if [[ "${repaired}" -eq 1 ]]; then
		"${ENGINE}" exec "${CONTAINER_NAME}" sh -c \
			"chown -R overlord:overlord ${RUNTIME_OPENCODE_CONFIG_DIR} 2>/dev/null || true"
		OPENCODE_WEB_RESTART_REQUIRED=1
	fi
}

restart_opencode_web_if_needed() {
	if [[ "${OPENCODE_WEB_RESTART_REQUIRED}" -ne 1 ]]; then
		return 0
	fi

	echo "Restarting OpenCode web server so package/config repairs take effect in ${CONTAINER_NAME}..."
	"${ENGINE}" exec -i "${CONTAINER_NAME}" sh -s -- "${OPENCODE_WEB_PID_FILE}" <<'EOF'
set -e

pid_file="$1"
if [ -s "${pid_file}" ]; then
	pid="$(cat "${pid_file}" 2>/dev/null || true)"
	if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
		kill "${pid}" 2>/dev/null || true
		for _ in 1 2 3 4 5; do
			if ! kill -0 "${pid}" 2>/dev/null; then
				break
			fi
			sleep 1
		done
	fi
fi
rm -f "${pid_file}"
EOF
}

request_opencode_web_restart_if_plugin_missing() {
	if [[ "${OPENCODE_WEB_RESTART_REQUIRED}" -eq 1 ]]; then
		return 0
	fi

	if "${ENGINE}" exec -i "${CONTAINER_NAME}" sh -s -- \
		"${OPENCODE_WEB_PID_FILE}" \
		"${CONTAINER_HOME}" <<'EOF'
pid_file="$1"
container_home="$2"
if [ ! -s "${pid_file}" ]; then
	exit 0
fi
pid="$(cat "${pid_file}" 2>/dev/null || true)"
if [ -z "${pid}" ] || ! kill -0 "${pid}" 2>/dev/null; then
	exit 0
fi
if [ ! -r "/proc/${pid}/environ" ]; then
	exit 0
fi
tr '\000' '\n' < "/proc/${pid}/environ" | grep -qx "HOME=${container_home}" && \
	tr '\000' '\n' < "/proc/${pid}/environ" | grep -qx "XDG_CONFIG_HOME=${container_home}/.config" && \
	tr '\000' '\n' < "/proc/${pid}/environ" | grep -qx "XDG_CACHE_HOME=${container_home}/.cache" && \
	tr '\000' '\n' < "/proc/${pid}/environ" | grep -qx "XDG_DATA_HOME=${container_home}/.local/share" && \
	tr '\000' '\n' < "/proc/${pid}/environ" | grep -qx "XDG_STATE_HOME=${container_home}/.local/state"
EOF
	then
		return 0
	fi

	echo "Restarting existing OpenCode web server because its HOME/XDG environment is not canonical in ${CONTAINER_NAME}..."
	OPENCODE_WEB_RESTART_REQUIRED=1
}

is_opencode_config_file() {
	local file_path="$1"
	local file_name

	file_name="$(basename "${file_path}")"
	[[ -f "${file_path}" ]] || return 1
	[[ "${file_name}" == opencode*.json ]] || return 1
	tr -d '[:space:]' <"${file_path}" | grep -Fq "${OPENCODE_CONFIG_SCHEMA}"
}

is_oh_my_config_file() {
	local file_path="$1"
	local file_name

	file_name="$(basename "${file_path}")"
	[[ -f "${file_path}" ]] || return 1
	[[ "${file_name}" == oh-my-openagent*.jsonc ]] || return 1
	grep -Fq "${OH_MY_CONFIG_SCHEMA}" "${file_path}"
}

print_available_configs() {
	local path
	local name
	local found=0

	echo "Available oh-my-openagent routing presets:"
	for path in "${OVERLORD_DIR}"/config/oh-my-openagent*.jsonc; do
		if is_oh_my_config_file "${path}"; then
			name="$(basename "${path}")"
			name="${name#oh-my-openagent}"
			name="${name%.jsonc}"
			name="${name#.}"
			printf '  %s (%s)\n' "${name:-default}" "$(basename "${path}")"
			found=1
		fi
	done

	if [[ "${found}" -eq 0 ]]; then
		echo "  (none found)"
	fi
}

# --- Parse command ---

CONFIG_NAME="${DEFAULT_OH_MY_CONFIG_NAME}"
CONFIG_EXPLICIT=0
LIST_CONFIGS=0
LMS_MODEL=""
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
	case "$1" in
	--list-configs)
		LIST_CONFIGS=1
		shift
		;;
	--config)
		if [[ $# -lt 2 ]]; then
			echo "Error: --config requires a routing preset" >&2
			echo "Run 'overlord --list-configs' to list available routing presets." >&2
			exit 1
		fi
		if [[ "$2" == -* ]]; then
			echo "Error: --config requires a routing preset" >&2
			echo "Run 'overlord --list-configs' to list available routing presets." >&2
			exit 1
		fi
		CONFIG_NAME="$2"
		CONFIG_EXPLICIT=1
		shift 2
		;;
	--lms-model)
		if [[ $# -lt 2 ]]; then
			echo "Error: --lms-model requires a model name" >&2
			echo "Example: overlord --lms-model nanbeige4.1-3b-mlx web" >&2
			exit 1
		fi
		if [[ "$2" == -* ]]; then
			echo "Error: --lms-model requires a model name" >&2
			echo "Example: overlord --lms-model nanbeige4.1-3b-mlx web" >&2
			exit 1
		fi
		LMS_MODEL="$2"
		shift 2
		;;
	-h | --help)
		POSITIONAL_ARGS+=("help")
		shift
		;;
	*)
		POSITIONAL_ARGS+=("$1")
		shift
		;;
	esac
done

if [[ "${LIST_CONFIGS}" -eq 1 ]]; then
	if [[ "${CONFIG_EXPLICIT}" -eq 1 || -n "${LMS_MODEL}" || ${#POSITIONAL_ARGS[@]} -gt 0 ]]; then
		echo "Error: --list-configs cannot be combined with commands or overrides" >&2
		exit 1
	fi
	print_available_configs
	exit 0
fi

CONFIG_FILE="${OVERLORD_DIR}/config/${OPENCODE_CONFIG_NAME}"
if ! is_opencode_config_file "${CONFIG_FILE}"; then
	echo "Error: ${CONFIG_FILE} is not a valid OpenCode provider catalog from config/" >&2
	exit 1
fi

if [[ ${#POSITIONAL_ARGS[@]} -gt 0 ]]; then
	set -- "${POSITIONAL_ARGS[@]}"
else
	set --
fi

COMMAND="${1:-web}"

if [[ $# -gt 1 ]]; then
	case "${2}" in
	bedrock | gemini | lms)
		echo "Error: positional provider overrides were removed" >&2
		echo "Use '--config <routing-preset>' for reviewed agent routing, or '--lms-model <model>' for ad hoc LM Studio models." >&2
		exit 1
		;;
	*)
		echo "Error: unexpected extra arguments: ${*:2}" >&2
		echo "Usage: overlord [--list-configs | --config PRESET | --lms-model MODEL] [command]" >&2
		exit 1
		;;
	esac
fi

resolve_oh_my_config_file() {
	local config_name="$1"
	local candidate

	if [[ "${config_name}" == */* ]]; then
		echo "Error: --config expects a preset name or filename from config/, not a path" >&2
		exit 1
	fi

	case "${config_name}" in
	default | "${DEFAULT_OH_MY_CONFIG_NAME}")
		candidate="${OVERLORD_DIR}/config/${DEFAULT_OH_MY_CONFIG_NAME}"
		;;
	opencode*.json)
		echo "Error: --config now selects oh-my-openagent routing presets, not OpenCode catalogs" >&2
		echo "Use '--config pro', '--config gemini', '--config opus', or '--config default'." >&2
		exit 1
		;;
	oh-my-openagent*.jsonc)
		candidate="${OVERLORD_DIR}/config/${config_name}"
		;;
	*)
		candidate="${OVERLORD_DIR}/config/oh-my-openagent.${config_name}.jsonc"
		;;
	esac

	if ! is_oh_my_config_file "${candidate}"; then
		echo "Error: routing preset '${config_name}' not found or invalid in ${OVERLORD_DIR}/config" >&2
		echo "Run 'overlord --list-configs' to list available routing presets." >&2
		exit 1
	fi

	printf '%s\n' "${candidate}"
}

if [[ "${CONFIG_EXPLICIT}" -eq 1 && -n "${LMS_MODEL}" ]]; then
	echo "Error: --config cannot be combined with --lms-model" >&2
	echo "Choose either a checked-in routing preset or an explicit LM Studio model." >&2
	exit 1
fi

MODEL_OVERRIDE=""
if [[ -n "${LMS_MODEL}" ]]; then
	MODEL_OVERRIDE="lmstudio/${LMS_MODEL}"
	echo "LM Studio override: all oh-my-openagent agents → ${MODEL_OVERRIDE}"
fi

OH_MY_CONFIG_FILE="$(resolve_oh_my_config_file "${CONFIG_NAME}")"
if [[ ! -f "${OH_MY_CONFIG_FILE}" ]]; then
	echo "Error: required routing config file '$(basename "${OH_MY_CONFIG_FILE}")' not found in ${OVERLORD_DIR}/config" >&2
	exit 1
fi

case "${COMMAND}" in
help | -h | --help)
	show_help
	exit 0
	;;
	fresh)
		stop_host_web_proxy
		backup_container_data
		clear_persisted_opencode_server_state
		echo "Removing container ${CONTAINER_NAME}..."
		"${ENGINE}" stop "${CONTAINER_NAME}" 2>/dev/null || true
		"${ENGINE}" rm "${CONTAINER_NAME}" 2>/dev/null || true
		echo "Done. Run 'overlord' to start fresh."
	exit 0
	;;
purge)
	stop_host_web_proxy
	backup_container_data
	echo "==> Removing container ${CONTAINER_NAME}..."
	"${ENGINE}" stop "${CONTAINER_NAME}" 2>/dev/null || true
	"${ENGINE}" rm "${CONTAINER_NAME}" 2>/dev/null || true

	if "${ENGINE}" image inspect "${IMAGE_NAME}" &>/dev/null; then
		echo "==> Removing image ${IMAGE_NAME}..."
		if ! "${ENGINE}" rmi "${IMAGE_NAME}"; then
			echo "Warning: image removal command reported a failure; verifying final image state..." >&2
		fi

		if "${ENGINE}" image inspect "${IMAGE_NAME}" &>/dev/null; then
			echo "Error: image ${IMAGE_NAME} still exists after purge; rebuild is not guaranteed." >&2
			exit 1
		fi
	else
		echo "==> Image ${IMAGE_NAME} is already absent."
	fi

	echo "==> Pruning dangling images..."
	"${ENGINE}" image prune -f --filter "dangling=true" 2>/dev/null || true
	echo "==> Done. Run 'overlord' to rebuild and launch."
	exit 0
	;;
web | opencode | shell | zellij) ;;
*)
	echo "Error: unknown command '${COMMAND}'" >&2
	echo "Run 'overlord help' for usage." >&2
	exit 1
	;;
esac

# --- Build (if needed) ---

ensure_image

# --- Env vars ---

EXEC_ENV=()
PACKAGE_ENV=()

pass_env() {
	local var="$1"
	if [[ -n "${!var:-}" ]]; then
		EXEC_ENV+=(-e "${var}=${!var}")
	fi
}

# Terminal
EXEC_ENV+=(-e "HOME=${CONTAINER_HOME}")
EXEC_ENV+=(-e "USER=overlord")
EXEC_ENV+=(-e "LOGNAME=overlord")
EXEC_ENV+=(-e "XDG_CONFIG_HOME=${CONTAINER_HOME}/.config")
EXEC_ENV+=(-e "XDG_CACHE_HOME=${CONTAINER_HOME}/.cache")
EXEC_ENV+=(-e "XDG_DATA_HOME=${CONTAINER_HOME}/.local/share")
EXEC_ENV+=(-e "XDG_STATE_HOME=${CONTAINER_HOME}/.local/state")
EXEC_ENV+=(-e "TERM=${TERM:-xterm-256color}")
EXEC_ENV+=(-e "OVERLORD_WORKSPACE=${ZELLIJ_SESSION}")
PACKAGE_ENV=(
	"HOME=${CONTAINER_HOME}"
	"USER=overlord"
	"LOGNAME=overlord"
	"XDG_CONFIG_HOME=${CONTAINER_HOME}/.config"
	"XDG_CACHE_HOME=${CONTAINER_HOME}/.cache"
	"XDG_DATA_HOME=${CONTAINER_HOME}/.local/share"
	"XDG_STATE_HOME=${CONTAINER_HOME}/.local/state"
	"BUN_INSTALL=${CONTAINER_HOME}/.bun"
	"UV_CACHE_DIR=${CONTAINER_HOME}/.cache/uv"
	"npm_config_cache=${CONTAINER_HOME}/.npm"
	"PATH=/usr/local/.safe-chain/shims:/usr/local/.safe-chain/bin:${CONTAINER_HOME}/.bun/bin:${CONTAINER_HOME}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
)
pass_env COLORTERM
pass_env TERM_PROGRAM
pass_env TERM_PROGRAM_VERSION
pass_env LANG
pass_env LC_ALL

# MCP credentials
pass_env CONTEXT7_API_KEY
pass_env EXA_API_KEY
pass_env TAVILY_API_KEY
pass_env OPENCODE_SERVER_PASSWORD

# Docker / Testcontainers runtime envs
: "${DOCKER_HOST:=unix:///var/run/docker.sock}"
: "${TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE:=/var/run/docker.sock}"
: "${TESTCONTAINERS_HOST_OVERRIDE:=host.docker.internal}"
export DOCKER_HOST TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE TESTCONTAINERS_HOST_OVERRIDE

# uv defaults for bind mounts and cache persistence
: "${UV_CACHE_DIR:=/home/overlord/.cache/uv}"
export UV_CACHE_DIR

# --- LM Studio defaults (host reachable from Docker via host.docker.internal) ---
: "${LMSTUDIO_BASE_URL:=http://host.docker.internal:1234/v1}"
: "${LMSTUDIO_API_KEY:=lm-studio}"
export LMSTUDIO_BASE_URL LMSTUDIO_API_KEY

# --- Normalize Google Cloud / Vertex AI env vars ---
# Users may set any of GOOGLE_CLOUD_LOCATION, VERTEX_LOCATION, etc.
# Normalize to the canonical names that {env:...} templates in opencode.json reference.
: "${GOOGLE_CLOUD_LOCATION:=${VERTEX_LOCATION:-}}"
: "${GOOGLE_CLOUD_PROJECT:=${GCP_PROJECT:-${GCLOUD_PROJECT:-}}}"
export GOOGLE_CLOUD_LOCATION GOOGLE_CLOUD_PROJECT

