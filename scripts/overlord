#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]:-$0}"

while [[ -L "${SOURCE}" ]]; do
	SOURCE_DIR="$(cd -P "$(dirname "${SOURCE}")" >/dev/null 2>&1 && pwd)"
	TARGET="$(readlink "${SOURCE}")"
	case "${TARGET}" in
	/*) SOURCE="${TARGET}" ;;
	*) SOURCE="${SOURCE_DIR}/${TARGET}" ;;
	esac
done

SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" >/dev/null 2>&1 && pwd)"

if ! PYTHON_BIN="$(command -v python3 2>/dev/null)"; then
	echo "Error: python3 not found in PATH. Install Python 3 to use overlord." >&2
	exit 127
fi

PYTHONPATH="${SCRIPT_DIR}${PYTHONPATH:+:${PYTHONPATH}}" exec "${PYTHON_BIN}" -m overlord_py.main "$@"
