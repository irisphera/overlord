{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "provider": {
    "amazon-bedrock": {
      "npm": "@ai-sdk/amazon-bedrock",
      "name": "AWS Bedrock",
      "models": {
        "global.anthropic.claude-opus-4-6-v1": {
          "name": "Claude Opus 4.6",
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 200000,
            "output": 32000
          }
        },
        "global.anthropic.claude-haiku-4-5-20251001-v1:0": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "google-vertex": {
      "npm": "@ai-sdk/google-vertex",
      "name": "Google Vertex AI",
      "options": {
        "project": "{env:GOOGLE_CLOUD_PROJECT}",
        "location": "global"
      },
      "models": {
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools"
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        }
      }
    },
    "azure": {
      "npm": "@ai-sdk/azure",
      "name": "Azure OpenAI",
      "env": [
        "AZURE_API_KEY"
      ],
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "id": "gpt-5.5-1",
          "options": {
            "serviceTier": "priority"
          },
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 32000
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "options": {
            "serviceTier": "priority"
          },
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 350000,
            "output": 65536
          }
        },
        "gpt-5.4-pro": {
          "name": "GPT-5.4 Pro",
          "options": {
            "serviceTier": "priority"
          },
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 350000,
            "output": 65536
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "id": "DeepSeek-V4-Pro",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "id": "DeepSeek-V4-Flash",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "{env:LMSTUDIO_BASE_URL}",
        "apiKey": "{env:LMSTUDIO_API_KEY}"
      },
      "models": {
        "lm-studio": {
          "name": "LM Studio (Local)"
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "minimax/minimax-m2.5:free": {
          "name": "MiniMax M2.5 (free)"
        }
      }
    }
  }
}
