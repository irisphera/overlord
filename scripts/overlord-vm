#!/usr/bin/env bash
set -euo pipefail

RESOLVED_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${RESOLVED_SCRIPT}")" && pwd)"
OVERLORD_DIR="$(dirname "${SCRIPT_DIR}")"

IMAGE_NAME="overlord-vm-devbox"
OPENCODE_CONFIG_NAME="opencode.json"
DEFAULT_OH_MY_CONFIG_NAME="oh-my-openagent.jsonc"
DEFAULT_ZELLIJ_CONFIG_NAME="zellij-config.kdl"
OPENCODE_CONFIG_SCHEMA="\"\$schema\": \"https://opencode.ai/config.json\""
OH_MY_CONFIG_SCHEMA="\"\$schema\": \"https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json\""
OPENCODE_REQUIRED_VERSION="1.4.6"
OPENCODE_WEB_HOSTNAME="127.0.0.1"
OPENCODE_WEB_PORT="4090"
OPENCODE_WEB_PID_FILE="/home/overlord/.local/share/opencode/overlord-serve.pid"
OPENCODE_WEB_LOG_FILE="/home/overlord/.local/share/opencode/overlord-serve.log"
OPENCODE_WEB_WAIT_SECONDS=90
SSH_LOGIN_HOST="127.0.0.1"
SSH_LOGIN_FALLBACK_HOST="host.docker.internal"
SSH_LOGIN_USER="overlord"
DEFAULT_LOCAL_TUNNEL_PORT="14090"
RUNTIME_CONFIG_DIR="/home/overlord/.config"
RUNTIME_OPENCODE_CONFIG_DIR="${RUNTIME_CONFIG_DIR}/opencode"
RUNTIME_OPENCODE_CONFIG_FILE="${RUNTIME_OPENCODE_CONFIG_DIR}/opencode.json"
RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE="${RUNTIME_OPENCODE_CONFIG_DIR}/oh-my-openagent.jsonc"
RUNTIME_ZELLIJ_CONFIG_DIR="${RUNTIME_CONFIG_DIR}/zellij"
RUNTIME_ZELLIJ_CONFIG_FILE="${RUNTIME_ZELLIJ_CONFIG_DIR}/config.kdl"
RUNTIME_OVERLORD_ENV_FILE="/home/overlord/.overlord-env"
RUNTIME_AUTHORIZED_KEYS_FILE="/home/overlord/.ssh/authorized_keys"
RUNTIME_ZSHENV_FILE="/home/overlord/.zshenv"
SSH_WORKSPACE_ZSHENV_BEGIN="# overlord-vm:ssh-workspace begin"
SSH_WORKSPACE_ZSHENV_END="# overlord-vm:ssh-workspace end"

show_help() {
	cat <<'USAGE'
overlord-vm - Manage SSH-first VM devbox containers

USAGE: overlord-vm [--config [preset]] command [options]

OPTIONS:
    --config [PRESET] List routing presets, or use one with config/opencode.json
    --user SLUG       Teammate slug ([a-z0-9][a-z0-9-]*)
    --ssh-port PORT   Host SSH port to publish (1024-65535)
    --pubkey FILE     Public key file to inject during container creation
    --purge-volumes   Remove named volumes during destroy (destroy only)

COMMANDS:
    create            Build image if needed, create volumes, and launch a teammate VM container
    start             Start an existing teammate VM container
    stop              Stop a running teammate VM container
    ssh               Open an SSH shell into a teammate VM container
    web               Start/reuse OpenCode and print the SSH tunnel command
    destroy           Remove a teammate VM container (volumes preserved by default)
    help              Show this help

NAMING:
    image             overlord-vm-devbox
    container         overlord-vm-<user>
    workspace         overlord-vm-<user>-workspace
    opencode          overlord-vm-<user>-opencode
    zsh               overlord-vm-<user>-zsh
    ssh               overlord-vm-<user>-ssh

EXAMPLES:
    overlord-vm help
    overlord-vm create --user alice --ssh-port 22221 --pubkey /tmp/alice_vm.pub
    overlord-vm create --config gemini --user alice --ssh-port 22221 --pubkey /tmp/alice_vm.pub
    overlord-vm start --user alice
    overlord-vm stop --user alice
    overlord-vm ssh --user alice
    overlord-vm web --user alice
    overlord-vm destroy --user alice
    overlord-vm destroy --user alice --purge-volumes

NOTES:
    VM mode is Docker-only and uses named volumes instead of bind mounts.
    SSH is the only published host port; OpenCode remains container-local for SSH tunneling.
USAGE
}

error() {
	echo "Error: $*" >&2
}

image_name() {
	printf '%s\n' "${IMAGE_NAME}"
}

container_name() {
	local user_slug="$1"
	printf 'overlord-vm-%s\n' "${user_slug}"
}

workspace_volume_name() {
	local user_slug="$1"
	printf 'overlord-vm-%s-workspace\n' "${user_slug}"
}

opencode_volume_name() {
	local user_slug="$1"
	printf 'overlord-vm-%s-opencode\n' "${user_slug}"
}

zsh_volume_name() {
	local user_slug="$1"
	printf 'overlord-vm-%s-zsh\n' "${user_slug}"
}

ssh_volume_name() {
	local user_slug="$1"
	printf 'overlord-vm-%s-ssh\n' "${user_slug}"
}

is_opencode_config_file() {
	local file_path="$1"
	local file_name

	file_name="$(basename "${file_path}")"
	[[ -f "${file_path}" ]] || return 1
	[[ "${file_name}" == opencode*.json ]] || return 1
	grep -Fq "${OPENCODE_CONFIG_SCHEMA}" "${file_path}"
}

is_oh_my_config_file() {
	local file_path="$1"
	local file_name

	file_name="$(basename "${file_path}")"
	[[ -f "${file_path}" ]] || return 1
	[[ "${file_name}" == oh-my-openagent*.jsonc ]] || return 1
	grep -Fq "${OH_MY_CONFIG_SCHEMA}" "${file_path}"
}

print_available_configs() {
	local path
	local name
	local found=0

	echo "Available oh-my-openagent routing presets:"
	for path in "${OVERLORD_DIR}"/config/oh-my-openagent*.jsonc; do
		if is_oh_my_config_file "${path}"; then
			name="$(basename "${path}")"
			name="${name#oh-my-openagent}"
			name="${name%.jsonc}"
			name="${name#.}"
			printf '  %s (%s)\n' "${name:-default}" "$(basename "${path}")"
			found=1
		fi
	done

	if [[ "${found}" -eq 0 ]]; then
		echo "  (none found)"
	fi
}

require_docker() {
	if ! command -v docker >/dev/null 2>&1; then
		error "docker is required for overlord-vm and was not found in PATH"
		exit 1
	fi
}

validate_user_slug() {
	if [[ -z "${USER_SLUG}" ]]; then
		error "--user is required for '${COMMAND}'"
		exit 1
	fi

	if [[ ! "${USER_SLUG}" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
		error "--user must match [a-z0-9][a-z0-9-]*"
		exit 1
	fi
}

validate_ssh_port() {
	if [[ -z "${SSH_PORT}" ]]; then
		error "--ssh-port is required for 'create'"
		exit 1
	fi

	if [[ ! "${SSH_PORT}" =~ ^[0-9]+$ ]]; then
		error "--ssh-port must be an integer between 1024 and 65535"
		exit 1
	fi

	if (( SSH_PORT < 1024 || SSH_PORT > 65535 )); then
		error "--ssh-port must be between 1024 and 65535"
		exit 1
	fi
}

validate_pubkey_file() {
	if [[ -z "${PUBKEY_FILE}" ]]; then
		error "--pubkey is required for 'create'"
		exit 1
	fi

	if [[ ! -f "${PUBKEY_FILE}" ]]; then
		error "public key file '${PUBKEY_FILE}' not found"
		exit 1
	fi

	if [[ ! -s "${PUBKEY_FILE}" ]]; then
		error "public key file '${PUBKEY_FILE}' is empty"
		exit 1
	fi
}

validate_config() {
	CONFIG_FILE="${OVERLORD_DIR}/config/${OPENCODE_CONFIG_NAME}"
	if ! is_opencode_config_file "${CONFIG_FILE}"; then
		error "${OPENCODE_CONFIG_NAME} is not a valid OpenCode provider catalog from config/"
		exit 1
	fi
}

resolve_oh_my_config_file() {
	local config_name="$1"
	local candidate

	if [[ "${config_name}" == */* ]]; then
		error "--config expects a preset name or filename from config/, not a path"
		exit 1
	fi

	case "${config_name}" in
	default | "${DEFAULT_OH_MY_CONFIG_NAME}")
		candidate="${OVERLORD_DIR}/config/${DEFAULT_OH_MY_CONFIG_NAME}"
		;;
	opencode*.json)
		error "--config now selects oh-my-openagent routing presets, not OpenCode catalogs"
		echo "Use '--config pro', '--config gemini', '--config opus', or '--config default'." >&2
		exit 1
		;;
	oh-my-openagent*.jsonc)
		candidate="${OVERLORD_DIR}/config/${config_name}"
		;;
	*)
		candidate="${OVERLORD_DIR}/config/oh-my-openagent.${config_name}.jsonc"
		;;
	esac

	if ! is_oh_my_config_file "${candidate}"; then
		error "routing preset '${config_name}' not found or invalid in ${OVERLORD_DIR}/config"
		echo "Run 'overlord-vm --config' to list available routing presets." >&2
		exit 1
	fi

	printf '%s\n' "${candidate}"
}

validate_option_usage_for_command() {
	case "${COMMAND}" in
	create)
		if [[ "${PURGE_VOLUMES}" -eq 1 ]]; then
			error "--purge-volumes is only supported with 'destroy'"
			exit 1
		fi
		return 0
		;;
	start | stop | ssh | web)
		if [[ -n "${SSH_PORT}" ]]; then
			error "--ssh-port is only supported with 'create'"
			exit 1
		fi
		if [[ -n "${PUBKEY_FILE}" ]]; then
			error "--pubkey is only supported with 'create'"
			exit 1
		fi
		if [[ "${PURGE_VOLUMES}" -eq 1 ]]; then
			error "--purge-volumes is only supported with 'destroy'"
			exit 1
		fi
		;;
	destroy)
		if [[ -n "${SSH_PORT}" ]]; then
			error "--ssh-port is only supported with 'create'"
			exit 1
		fi
		if [[ -n "${PUBKEY_FILE}" ]]; then
			error "--pubkey is only supported with 'create'"
			exit 1
		fi
		;;
	esac
}

build_image() {
	echo "Building ${IMAGE_NAME} from ${OVERLORD_DIR}/Dockerfile.vm..."
	if docker buildx version >/dev/null 2>&1; then
		docker buildx build --load -f "${OVERLORD_DIR}/Dockerfile.vm" -t "${IMAGE_NAME}" "${OVERLORD_DIR}"
	else
		docker build -f "${OVERLORD_DIR}/Dockerfile.vm" -t "${IMAGE_NAME}" "${OVERLORD_DIR}"
	fi
}

ensure_image() {
	if ! docker image inspect "${IMAGE_NAME}" >/dev/null 2>&1; then
		build_image
	fi
}

container_state() {
	local container="$1"
	local state

	state=$(docker inspect --format '{{.State.Status}}' "${container}" 2>/dev/null) || true
	echo "${state:-missing}"
}

require_existing_container() {
	local container="$1"

	if [[ "$(container_state "${container}")" == "missing" ]]; then
		error "container ${container} does not exist"
		exit 1
	fi
}

require_missing_container() {
	local container="$1"

	if [[ "$(container_state "${container}")" != "missing" ]]; then
		error "container ${container} already exists"
		exit 1
	fi
}

resolve_published_ssh_port() {
	local container="$1"
	local published
	local line

	published=$(docker port "${container}" "22/tcp" 2>/dev/null || true)
	if [[ -z "${published}" ]]; then
		error "container ${container} does not publish SSH on 22/tcp"
		exit 1
	fi

	while IFS= read -r line; do
		if [[ "${line}" =~ :([0-9]+)$ ]]; then
			printf '%s\n' "${BASH_REMATCH[1]}"
			return 0
		fi
	done <<<"${published}"

	error "could not resolve the published SSH port for ${container}"
	exit 1
}

ensure_no_published_web_port() {
	local container="$1"
	local published

	published=$(docker port "${container}" "${OPENCODE_WEB_PORT}/tcp" 2>/dev/null || true)
	if [[ -n "${published}" ]]; then
		error "container ${container} unexpectedly publishes ${OPENCODE_WEB_PORT}/tcp"
		error "destroy and recreate the VM container so OpenCode stays tunnel-only"
		exit 1
	fi
}

can_connect_to_host_port() {
	local host="$1"
	local port="$2"

	if ! command -v python3 >/dev/null 2>&1; then
		return 1
	fi

	python3 - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])

try:
    infos = socket.getaddrinfo(host, port, type=socket.SOCK_STREAM)
except OSError:
    raise SystemExit(1)

for family, socktype, proto, _, sockaddr in infos:
    sock = socket.socket(family, socktype, proto)
    sock.settimeout(1)
    try:
        sock.connect(sockaddr)
    except OSError:
        sock.close()
        continue
    sock.close()
    raise SystemExit(0)

raise SystemExit(1)
PY
}

resolve_ssh_login_host() {
	local ssh_port="$1"

	if can_connect_to_host_port "${SSH_LOGIN_HOST}" "${ssh_port}"; then
		printf '%s\n' "${SSH_LOGIN_HOST}"
		return 0
	fi

	if can_connect_to_host_port "${SSH_LOGIN_FALLBACK_HOST}" "${ssh_port}"; then
		printf '%s\n' "${SSH_LOGIN_FALLBACK_HOST}"
		return 0
	fi

	printf '%s\n' "${SSH_LOGIN_HOST}"
}

ensure_container_running() {
	local container="$1"
	local state

	state="$(container_state "${container}")"
	case "${state}" in
	missing)
		error "container ${container} does not exist"
		exit 1
		;;
	running)
		;;
	exited)
		echo "Starting ${container}..."
		docker start "${container}" >/dev/null
		initialize_runtime_state "${container}"
		;;
	*)
		error "container ${container} is in unexpected state: ${state}"
		exit 1
		;;
	esac

	ensure_ssh_login_account_ready "${container}"
	ensure_ssh_workspace_shell_entry "${container}"
}

ensure_opencode_runtime_version() {
	local container="$1"
	local current_version
	local installed_version

	current_version=$(docker exec -u overlord "${container}" opencode --version 2>/dev/null || true)
	if [[ "${current_version}" == "${OPENCODE_REQUIRED_VERSION}" ]]; then
		return 0
	fi

	echo "Ensuring OpenCode CLI package opencode-ai@${OPENCODE_REQUIRED_VERSION} in ${container}..."
	docker exec -u overlord "${container}" sh -s -- "${OPENCODE_REQUIRED_VERSION}" <<'EOF'
set -e

required_version="$1"
install_log="$(mktemp)"

cleanup() {
	rm -f "${install_log}"
}

trap cleanup EXIT

if ! bun add -g "opencode-ai@${required_version}" >"${install_log}" 2>&1; then
	cat "${install_log}" >&2
	exit 1
fi
EOF
	installed_version=$(docker exec -u overlord "${container}" opencode --version 2>/dev/null || true)
	printf 'OpenCode CLI version: %s\n' "${installed_version:-unknown}"
}

wait_for_opencode_web() {
	local container="$1"
	local health_url="http://127.0.0.1:${OPENCODE_WEB_PORT}/global/health"
	local attempt

	for ((attempt = 1; attempt <= OPENCODE_WEB_WAIT_SECONDS; attempt += 1)); do
		if docker exec -i -u overlord "${container}" sh -s -- "${health_url}" "${RUNTIME_OVERLORD_ENV_FILE}" <<'EOF' >/dev/null 2>&1
URL="$1"
ENV_FILE="$2"

if [ -f "${ENV_FILE}" ]; then
  set -a
  . "${ENV_FILE}"
  set +a
fi

if [ -n "${OPENCODE_SERVER_PASSWORD:-}" ]; then
  exec curl --silent --fail --max-time 5 -u "opencode:${OPENCODE_SERVER_PASSWORD}" "${URL}"
fi

exec curl --silent --fail --max-time 5 "${URL}"
EOF
		then
			return 0
		fi
		sleep 1
	done

	error "OpenCode web UI did not become healthy at ${health_url} in ${container}"
	error "Check ${OPENCODE_WEB_LOG_FILE} inside ${container} for startup errors."
	exit 1
}

ensure_opencode_web_server() {
	local container="$1"

	ensure_no_published_web_port "${container}"
	ensure_opencode_runtime_version "${container}"

	echo "Ensuring OpenCode web server is running in ${container}..."
	docker exec -i -w /workspace -u overlord "${container}" \
		sh -s -- "${OPENCODE_WEB_PID_FILE}" "${OPENCODE_WEB_LOG_FILE}" "${OPENCODE_WEB_HOSTNAME}" "${OPENCODE_WEB_PORT}" "${RUNTIME_OVERLORD_ENV_FILE}" <<'EOF'
PID_FILE="$1"
LOG_FILE="$2"
HOST="$3"
PORT="$4"
ENV_FILE="$5"

if [ -s "${PID_FILE}" ]; then
  PID=$(cat "${PID_FILE}" 2>/dev/null || true)
  if [ -n "${PID}" ] && kill -0 "${PID}" 2>/dev/null && [ -r "/proc/${PID}/cmdline" ]; then
    CMDLINE=$(tr '\000' ' ' < "/proc/${PID}/cmdline")
    case "${CMDLINE}" in
      *"opencode web --hostname ${HOST} --port ${PORT}"*)
        exit 0
        ;;
      *"opencode web --hostname "*|\
      *"opencode web --pure --hostname "*|\
      *"opencode serve --hostname "*)
        kill "${PID}" 2>/dev/null || true
        for _ in 1 2 3 4 5; do
          if ! kill -0 "${PID}" 2>/dev/null; then
            break
          fi
          sleep 1
        done
        rm -f "${PID_FILE}"
        ;;
      *)
        rm -f "${PID_FILE}"
        ;;
    esac
  fi
fi

mkdir -p "$(dirname "${PID_FILE}")"
if [ -f "${ENV_FILE}" ]; then
  set -a
  . "${ENV_FILE}"
  set +a
fi
		nohup opencode web --hostname "${HOST}" --port "${PORT}" >"${LOG_FILE}" 2>&1 &
	echo $! >"${PID_FILE}"
EOF

	wait_for_opencode_web "${container}"
}

ensure_named_volume() {
	local volume="$1"

	if docker volume inspect "${volume}" >/dev/null 2>&1; then
		return 0
	fi

	docker volume create "${volume}" >/dev/null
	CREATED_VOLUMES+=("${volume}")
}

cleanup_failed_create() {
	local container="$1"
	local volume

	docker rm -f "${container}" >/dev/null 2>&1 || true
	for volume in "${CREATED_VOLUMES[@]}"; do
		docker volume rm "${volume}" >/dev/null 2>&1 || true
	done
}

copy_file_into_container() {
	local container="$1"
	local source_file="$2"
	local target_file="$3"

	docker exec -i "${container}" sh -c 'cat > "$1"' sh "${target_file}" <"${source_file}"
}

ensure_runtime_paths() {
	local container="$1"

	docker exec "${container}" sh <<'EOF'
set -eu
mkdir -p /workspace
mkdir -p /home/overlord/.ssh
mkdir -p /home/overlord/.config/opencode
mkdir -p /home/overlord/.config/zellij
mkdir -p /home/overlord/.local/share/opencode
mkdir -p /home/overlord/.zsh_data
chmod 755 /home/overlord
chmod 700 /home/overlord/.ssh
chown -R overlord:overlord \
  /workspace \
  /home/overlord/.ssh \
  /home/overlord/.config \
  /home/overlord/.local/share/opencode \
  /home/overlord/.zsh_data
EOF
}

ensure_runtime_config_assets() {
	local container="$1"

	ensure_runtime_paths "${container}"
	copy_file_into_container "${container}" "${CONFIG_FILE}" "${RUNTIME_OPENCODE_CONFIG_FILE}"
	copy_file_into_container "${container}" "${OH_MY_CONFIG_FILE}" "${RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE}"
	copy_file_into_container "${container}" "${ZELLIJ_CONFIG_FILE}" "${RUNTIME_ZELLIJ_CONFIG_FILE}"

	docker exec "${container}" sh -c '
		chown overlord:overlord "$1" "$2" "$3"
		chmod 644 "$1" "$2" "$3"
	' sh "${RUNTIME_OPENCODE_CONFIG_FILE}" "${RUNTIME_OH_MY_OPENAGENT_CONFIG_FILE}" "${RUNTIME_ZELLIJ_CONFIG_FILE}"
}

ensure_ssh_login_account_ready() {
	local container="$1"

	# Ubuntu's locked-password default blocks pubkey SSH for this account in the
	# current sshd setup, so make the account key-login-ready while password auth
	# remains disabled by sshd_config.
	docker exec "${container}" sh -c 'passwd -d overlord >/dev/null 2>&1 || true; passwd -u overlord >/dev/null 2>&1 || true'
}

ensure_overlord_env_template() {
	local container="$1"

	docker exec "${container}" sh -c '
		if [ ! -f "$1" ]; then
			cat > "$1" <<"EOF"
# Overlord VM runtime environment
# Add credentials or overrides here, for example:
# export OPENAI_API_KEY="..."
EOF
		fi
		chown overlord:overlord "$1"
		chmod 600 "$1"
	' sh "${RUNTIME_OVERLORD_ENV_FILE}"
}

ensure_ssh_workspace_shell_entry() {
	local container="$1"

	docker exec -i "${container}" python3 - "${RUNTIME_ZSHENV_FILE}" "${SSH_WORKSPACE_ZSHENV_BEGIN}" "${SSH_WORKSPACE_ZSHENV_END}" <<'PY'
from pathlib import Path
import os
import pwd
import sys

path = Path(sys.argv[1])
begin = sys.argv[2]
end = sys.argv[3]

block = "\n".join(
    [
        begin,
        'if [ -n "${SSH_CONNECTION:-}" ] && [ -d /workspace ] && [ "${PWD:-$HOME}" = "$HOME" ]; then',
        '  cd /workspace || exit 1',
        'fi',
        end,
    ]
)

text = path.read_text() if path.exists() else ""
if begin in text:
    start = text.index(begin)
    tail = text[start:]
    if end in tail:
        finish = start + tail.index(end) + len(end)
        if finish < len(text) and text[finish:finish + 1] == "\n":
            finish += 1
    else:
        finish = len(text)
    prefix = text[:start].rstrip("\n")
    text = (prefix + "\n\n" if prefix else "") + block + "\n"
else:
    if text and not text.endswith("\n"):
        text += "\n"
    if text.strip():
        text += "\n"
    text += block + "\n"

path.write_text(text)
entry = pwd.getpwnam("overlord")
os.chown(path, entry.pw_uid, entry.pw_gid)
os.chmod(path, 0o644)
PY
}

inject_authorized_key() {
	local container="$1"
	local pubkey

	pubkey="$(tr -d '\r' <"${PUBKEY_FILE}")"
	printf '%s\n' "${pubkey}" | docker exec -i "${container}" sh -c '
		set -eu
		read -r pubkey
		mkdir -p /home/overlord/.ssh
		touch "$1"
		if ! grep -Fqx "$pubkey" "$1" 2>/dev/null; then
			printf "%s\n" "$pubkey" >> "$1"
		fi
		chown overlord:overlord /home/overlord/.ssh "$1"
		chmod 700 /home/overlord/.ssh
		chmod 600 "$1"
	' sh "${RUNTIME_AUTHORIZED_KEYS_FILE}"
}

initialize_runtime_state() {
	local container="$1"

	ensure_runtime_config_assets "${container}"
	ensure_overlord_env_template "${container}"
	ensure_ssh_login_account_ready "${container}"
	ensure_ssh_workspace_shell_entry "${container}"
}

run_create_container() {
	local container="$1"
	local workspace_volume="$2"
	local opencode_volume="$3"
	local zsh_volume="$4"
	local ssh_volume="$5"

		docker run -d \
			--name "${container}" \
			-p "${SSH_PORT}:22" \
			-v "${workspace_volume}:/workspace" \
			-v "${opencode_volume}:/home/overlord/.local/share/opencode" \
			-v "${zsh_volume}:/home/overlord/.zsh_data" \
			-v "${ssh_volume}:/etc/ssh" \
			"${IMAGE_NAME}" >/dev/null
}

perform_create_sequence() {
	local container="$1"
	local workspace_volume="$2"
	local opencode_volume="$3"
	local zsh_volume="$4"
	local ssh_volume="$5"

	ensure_image &&
		ensure_named_volume "${workspace_volume}" &&
		ensure_named_volume "${opencode_volume}" &&
		ensure_named_volume "${zsh_volume}" &&
		ensure_named_volume "${ssh_volume}" &&
		run_create_container "${container}" "${workspace_volume}" "${opencode_volume}" "${zsh_volume}" "${ssh_volume}" &&
		initialize_runtime_state "${container}" &&
		inject_authorized_key "${container}"
}

create_command() {
	local container
	local workspace_volume
	local opencode_volume
	local zsh_volume
	local ssh_volume

	container="$(container_name "${USER_SLUG}")"
	workspace_volume="$(workspace_volume_name "${USER_SLUG}")"
	opencode_volume="$(opencode_volume_name "${USER_SLUG}")"
	zsh_volume="$(zsh_volume_name "${USER_SLUG}")"
	ssh_volume="$(ssh_volume_name "${USER_SLUG}")"
	CREATED_VOLUMES=()

	require_missing_container "${container}"

	if ! perform_create_sequence "${container}" "${workspace_volume}" "${opencode_volume}" "${zsh_volume}" "${ssh_volume}"; then
		cleanup_failed_create "${container}"
		exit 1
	fi

	echo "Created ${container}."
}

start_command() {
	local container
	local state

	container="$(container_name "${USER_SLUG}")"
	state="$(container_state "${container}")"

	case "${state}" in
	missing)
		error "container ${container} does not exist"
		exit 1
		;;
	running)
		echo "Container ${container} is already running."
		;;
	exited)
		echo "Starting ${container}..."
		docker start "${container}" >/dev/null
		;;
	*)
		error "container ${container} is in unexpected state: ${state}"
		exit 1
		;;
	esac

	initialize_runtime_state "${container}"
}

stop_command() {
	local container
	local state

	container="$(container_name "${USER_SLUG}")"
	state="$(container_state "${container}")"

	case "${state}" in
	missing)
		error "container ${container} does not exist"
		exit 1
		;;
	running)
		echo "Stopping ${container}..."
		docker stop "${container}" >/dev/null
		;;
	exited)
		echo "Container ${container} is already stopped."
		;;
	*)
		error "container ${container} is in unexpected state: ${state}"
		exit 1
		;;
	esac
}

destroy_command() {
	local container
	local state
	local volume

	container="$(container_name "${USER_SLUG}")"
	state="$(container_state "${container}")"

	if [[ "${state}" != "missing" ]]; then
		echo "Removing ${container}..."
		docker rm -f "${container}" >/dev/null
	elif [[ "${PURGE_VOLUMES}" -ne 1 ]]; then
		error "container ${container} does not exist"
		exit 1
	fi

	if [[ "${PURGE_VOLUMES}" -eq 1 ]]; then
		for volume in \
			"$(workspace_volume_name "${USER_SLUG}")" \
			"$(opencode_volume_name "${USER_SLUG}")" \
			"$(zsh_volume_name "${USER_SLUG}")" \
			"$(ssh_volume_name "${USER_SLUG}")"; do
			docker volume rm "${volume}" >/dev/null 2>&1 || true
		done
		echo "Removed ${container} and its named volumes."
	else
		echo "Removed ${container}. Named volumes were preserved."
	fi
}

ssh_command() {
	local container
	local ssh_host
	local ssh_port

	container="$(container_name "${USER_SLUG}")"
	ensure_container_running "${container}"
	ssh_port="$(resolve_published_ssh_port "${container}")"
	ssh_host="$(resolve_ssh_login_host "${ssh_port}")"
	exec ssh -p "${ssh_port}" "${SSH_LOGIN_USER}@${ssh_host}"
}

web_command() {
	local container
	local ssh_host
	local ssh_port

	container="$(container_name "${USER_SLUG}")"
	ensure_container_running "${container}"
	ssh_port="$(resolve_published_ssh_port "${container}")"
	ssh_host="$(resolve_ssh_login_host "${ssh_port}")"
	ensure_opencode_web_server "${container}"
	printf 'OpenCode is running in %s on container-local http://127.0.0.1:%s\n' "${container}" "${OPENCODE_WEB_PORT}"
	printf 'SSH tunnel: ssh -fN -L %s:127.0.0.1:%s -p %s %s@%s\n' \
		"${DEFAULT_LOCAL_TUNNEL_PORT}" \
		"${OPENCODE_WEB_PORT}" \
		"${ssh_port}" \
		"${SSH_LOGIN_USER}" \
		"${ssh_host}"
	printf 'Then open: http://127.0.0.1:%s\n' "${DEFAULT_LOCAL_TUNNEL_PORT}"
}

CONFIG_NAME="${DEFAULT_OH_MY_CONFIG_NAME}"
CONFIG_FILE=""
OH_MY_CONFIG_FILE="${OVERLORD_DIR}/config/${DEFAULT_OH_MY_CONFIG_NAME}"
ZELLIJ_CONFIG_FILE="${OVERLORD_DIR}/config/${DEFAULT_ZELLIJ_CONFIG_NAME}"
USER_SLUG=""
SSH_PORT=""
PUBKEY_FILE=""
PURGE_VOLUMES=0
CREATED_VOLUMES=()
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
	case "$1" in
	--config)
		if [[ $# -lt 2 ]]; then
			print_available_configs
			exit 0
		fi
		if [[ "$2" == -* ]]; then
			error "--config requires a routing preset"
			echo "Run 'overlord-vm --config' to list available routing presets." >&2
			exit 1
		fi
		CONFIG_NAME="$2"
		shift 2
		;;
	--user)
		if [[ $# -lt 2 || "$2" == -* ]]; then
			error "--user requires a slug"
			exit 1
		fi
		USER_SLUG="$2"
		shift 2
		;;
	--ssh-port)
		if [[ $# -lt 2 || "$2" == -* ]]; then
			error "--ssh-port requires a port number"
			exit 1
		fi
		SSH_PORT="$2"
		shift 2
		;;
	--pubkey)
		if [[ $# -lt 2 || "$2" == -* ]]; then
			error "--pubkey requires a file path"
			exit 1
		fi
		PUBKEY_FILE="$2"
		shift 2
		;;
	--purge-volumes)
		PURGE_VOLUMES=1
		shift
		;;
	-h | --help)
		POSITIONAL_ARGS+=("help")
		shift
		;;
	*)
		POSITIONAL_ARGS+=("$1")
		shift
		;;
	esac
done

if [[ ! -f "${OH_MY_CONFIG_FILE}" ]]; then
	error "required config file '$(basename "${OH_MY_CONFIG_FILE}")' not found in ${OVERLORD_DIR}/config"
	exit 1
fi

if [[ ! -f "${ZELLIJ_CONFIG_FILE}" ]]; then
	error "required config file '$(basename "${ZELLIJ_CONFIG_FILE}")' not found in ${OVERLORD_DIR}/config"
	exit 1
fi

if [[ ${#POSITIONAL_ARGS[@]} -gt 1 ]]; then
	error "unexpected argument '${POSITIONAL_ARGS[1]}'"
	echo "Run 'overlord-vm help' for usage." >&2
	exit 1
fi

if [[ ${#POSITIONAL_ARGS[@]} -gt 0 ]]; then
	COMMAND="${POSITIONAL_ARGS[0]}"
else
	COMMAND="help"
fi

case "${COMMAND}" in
help)
	show_help
	exit 0
	;;
create | start | stop | ssh | web | destroy)
	validate_user_slug
	validate_config
	OH_MY_CONFIG_FILE="$(resolve_oh_my_config_file "${CONFIG_NAME}")"
	if [[ ! -f "${OH_MY_CONFIG_FILE}" ]]; then
		error "required config file '$(basename "${OH_MY_CONFIG_FILE}")' not found in ${OVERLORD_DIR}/config"
		exit 1
	fi
	validate_option_usage_for_command
	case "${COMMAND}" in
	create)
		validate_ssh_port
		validate_pubkey_file
		;;
	esac
	require_docker
	case "${COMMAND}" in
	create)
		create_command
		;;
	start)
		start_command
		;;
	stop)
		stop_command
		;;
		ssh)
			ssh_command
			;;
		web)
			web_command
			;;
	destroy)
		destroy_command
		;;
	esac
	;;
*)
	error "unknown command '${COMMAND}'"
	echo "Run 'overlord-vm help' for usage." >&2
	exit 1
	;;
esac
