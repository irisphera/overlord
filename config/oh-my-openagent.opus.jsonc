{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  },
  "team_mode": {
    "enabled": true
  },
  "codegraph": {
    "enabled": true,
    "auto_provision": true,
    "telemetry": false
  },
  "categories": {
    // HIGH reasoning — deep logical work, complex problem-solving
    "ultrabrain": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    "unspecified-high": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    // MEDIUM reasoning — balanced effort for creative, visual, and writing tasks
    "visual-engineering": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "artistry": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "writing": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    // LOW reasoning — trivial, fast tasks
    "quick": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "low"
    }
  },
  "agents": {
    // HIGH reasoning — orchestration, architecture, planning, deep execution
    "sisyphus": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    "atlas": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    "oracle": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    "prometheus": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    "hephaestus": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    "plan": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "high"
    },
    // MEDIUM reasoning — validation, building, general work
    "sisyphus-junior": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "OpenCode-Builder": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "build": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "metis": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "momus": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    "multimodal-looker": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "medium"
    },
    // LOW reasoning — search, lookup, exploration (speed over depth)
    "explore": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "low",
      "category": "unspecified-low"
    },
    "librarian": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
      "reasoningEffort": "low",
      "category": "unspecified-low"
    }
  }
}
