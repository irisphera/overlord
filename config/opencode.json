{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "lsp": true,
  "permission": {
    "lsp": "allow"
  },
  "provider": {
    "amazon-bedrock": {
      "npm": "@ai-sdk/amazon-bedrock",
      "name": "AWS Bedrock",
      "models": {
        "global.anthropic.claude-opus-4-8-v1": {
          "name": "Claude Opus 4.8",
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 32000
          }
        },
        "global.anthropic.claude-haiku-4-5-20251001-v1:0": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "google-vertex": {
      "npm": "@ai-sdk/google-vertex",
      "name": "Google Vertex AI",
      "options": {
        "project": "{env:GOOGLE_CLOUD_PROJECT}",
        "location": "global"
      },
      "models": {
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools"
        },
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash",
          "tool_call": true
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        }
      }
    },
    "azure": {
      "npm": "@ai-sdk/azure",
      "name": "Azure OpenAI",
      "env": [
        "AZURE_API_KEY"
      ],
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol",
          "id": "gpt-5.6-sol",
          "options": {
            "serviceTier": "priority"
          },
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000
          }
        },
        "gpt-5.6-terra": {
          "name": "GPT-5.6 Terra",
          "id": "gpt-5.6-terra",
          "options": {
            "serviceTier": "priority"
          },
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "{env:LMSTUDIO_BASE_URL}",
        "apiKey": "{env:LMSTUDIO_API_KEY}"
      },
      "models": {
        "qwopus3.5-9b-coder-mtp": {
          "name": "qwopus3.5-9b-coder-mtp"
        }
      }
    }
  }
}
