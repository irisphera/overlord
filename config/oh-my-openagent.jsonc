{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  },
  "team_mode": {
    "enabled": true
  },
  "codegraph": {
    "enabled": true,
    "auto_provision": true,
    "telemetry": false
  },
  "categories": {
    // HIGH reasoning — deep logical work, complex problem-solving
    "ultrabrain": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "xhigh"
    },
    "unspecified-high": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "high"
    },
    // MEDIUM reasoning — balanced effort for creative, visual, and writing tasks
    "visual-engineering": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium"
    },
    "artistry": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium"
    },
    "writing": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium"
    },
    // LOW reasoning — trivial, fast tasks
    "quick": {
      "model": "azure/gpt-5.6-luna",
      "reasoningEffort": "high"
    },
    "unspecified-low": {
      "model": "azure/gpt-5.6-luna",
      "reasoningEffort": "high"
    }
  },
  "agents": {
    // HIGH reasoning — orchestration, architecture, planning, deep execution
    "sisyphus": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "OUTCOME DISCIPLINE: Keep the user's smallest observable success criterion above every process artifact. For implementation, deliver the thinnest working end-to-end slice and run it through its real user-facing surface before expanding architecture. Plans, abstractions, tests, infrastructure, compatibility, hardening, and documentation are not progress unless they enable or protect an explicit current requirement. Do not add speculative subsystems for possible future needs. Before adding unrequested machinery, identify the concrete present failure it prevents and why the simpler path fails; without that evidence, omit it. Re-check the acceptance behavior after each milestone. Stop when the requested behavior works, focused checks pass, and no explicit requirement remains; list optional improvements instead of implementing them."
    },
    "atlas": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "EXECUTION DISCIPLINE: Treat a working user-visible outcome as the governing objective, not completion of plan sections or production of artifacts. Preserve or establish the earliest runnable vertical slice, exercise it through the real surface, and keep it working after each milestone. Challenge plan steps that add abstractions, infrastructure, broad tests, hardening, recovery, compatibility, or future-facing machinery before an explicit current requirement needs them. If a step does not advance or protect the acceptance behavior, skip it and record why. Stop once the requested behavior and focused verification are complete."
    },
    "oracle": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "xhigh",
      "prompt_append": "TASTE CHECK: Optimize recommendations for the smallest sufficient solution to the user's actual observable outcome. Distinguish demonstrated constraints from hypothetical future concerns. Explicitly flag proxy-objective capture, speculative hardening, architecture-before-evidence, and process artifacts that do not enable or protect a current requirement. Prefer deleting or avoiding machinery over completing it. Recommend added complexity only when you can name the concrete present failure the simpler design cannot handle."
    },
    "prometheus": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "PLANNING DISCIPLINE: Make the first milestone the smallest user-observable end-to-end behavior that proves the request works, including its exact acceptance command or interaction. Plan in vertical slices, not complete internal layers. Keep the plan proportional and decision-complete only for current requirements; do not invent validation, persistence, locking, retries, recovery, compatibility, adapters, abstractions, or broad test matrices without evidence that the requested behavior needs them now. Every later milestone must advance or protect the acceptance behavior. End the plan at the requested outcome and put possible future improvements in a clearly non-executing note."
    },
    "hephaestus": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "OUTCOME DISCIPLINE: Build the thinnest working end-to-end slice first and run it through the real user-facing surface. Do not substitute architecture, infrastructure, tests, plans, or hardening for working behavior. Add unrequested machinery only to address a concrete present failure that the simpler implementation demonstrably cannot handle. Keep changes proportional, re-run the acceptance behavior after each milestone, and stop when the explicit request and focused checks are satisfied."
    },
    "plan": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "PLANNING DISCIPLINE: Lead with one observable acceptance criterion and the earliest runnable vertical slice. Prefer a short sequence that delivers user value over exhaustive inventories or complete internal layers. Do not introduce speculative abstractions, persistence, validation, locking, retries, recovery, compatibility, adapters, or broad testing unless an explicit requirement or demonstrated failure makes them necessary. Each step must advance or protect the acceptance behavior. Stop the plan when the requested outcome is achieved; do not turn optional future work into required scope."
    },
    // MEDIUM reasoning — validation, building, general work
    "sisyphus-junior": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "IMPLEMENTATION DISCIPLINE: Preserve the user's observable acceptance behavior as the dominant objective. Implement the smallest complete vertical slice, run it through the real surface, and only then add what a current requirement or observed failure demands. Do not add speculative abstractions, infrastructure, hardening, compatibility, or broad tests. If a requested plan contains machinery that does not advance or protect the acceptance behavior, use the simpler path and report the deviation. Stop when the requested behavior works and focused verification passes."
    },
    "OpenCode-Builder": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "IMPLEMENTATION DISCIPLINE: Deliver and manually exercise the thinnest user-visible end-to-end slice before expanding internals. Plans, abstractions, tests, infrastructure, hardening, and documentation do not substitute for working behavior. Add complexity only for an explicit current requirement or a demonstrated failure of the simpler path. Re-run the acceptance behavior after meaningful changes and stop when the request and focused checks are complete."
    },
    "build": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "IMPLEMENTATION DISCIPLINE: Deliver and manually exercise the thinnest user-visible end-to-end slice before expanding internals. Plans, abstractions, tests, infrastructure, hardening, and documentation do not substitute for working behavior. Add complexity only for an explicit current requirement or a demonstrated failure of the simpler path. Re-run the acceptance behavior after meaningful changes and stop when the request and focused checks are complete."
    },
    "metis": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "xhigh",
      "prompt_append": "SCOPE DISCIPLINE: Identify the user's smallest observable success criterion, the earliest vertical slice, and the minimum decisions needed to execute it. Treat speculative future needs and exhaustive completeness as risks, not requirements. Flag ambiguity only when it materially changes the acceptance behavior or implementation boundary. Recommend the simplest sufficient scope and explicitly reject proxy progress such as plans, infrastructure, abstractions, or tests that can grow while the requested workflow remains unusable."
    },
    "momus": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "xhigh",
      "prompt_append": "PLAN REVIEW DISCIPLINE: Reject any plan that can produce substantial architecture, infrastructure, tests, or documentation before a runnable user-visible vertical slice. Require an explicit acceptance command or interaction, make the first milestone exercise it end to end, and ensure every later step advances or protects that behavior. Flag speculative hardening, future-proofing, unnecessary abstractions, exhaustive inventories, and artifact-driven progress. A plan is not better because it is longer; prefer the smallest plan that safely delivers the explicit request."
    },
    "multimodal-looker": {
      "model": "azure/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt_append": "ANALYSIS DISCIPLINE: Report only evidence relevant to the user's decision or acceptance criterion. Separate visible facts from inference, avoid exhaustive inventories that do not change the conclusion, and stop once the requested evidence is sufficient."
    },
    // LOW reasoning — search, lookup, exploration (speed over depth)
    "explore": {
      "model": "azure/gpt-5.6-luna",
      "reasoningEffort": "high",
      "category": "unspecified-low",
      "prompt_append": "SEARCH DISCIPLINE: Search only to resolve the stated downstream decision. Return the minimum evidence needed, distinguish current requirements from hypothetical concerns, and stop when the decision is unblocked or repeated searches stop adding material information. Do not propose architecture or extra scope."
    },
    "librarian": {
      "model": "azure/gpt-5.6-luna",
      "reasoningEffort": "high",
      "category": "unspecified-low",
      "prompt_append": "RESEARCH DISCIPLINE: Research only to resolve the stated downstream decision. Prefer authoritative evidence, return the minimum findings that change the answer, and stop when the decision is unblocked or sources converge. Do not expand the task into adjacent best practices, architecture, or possible future needs."
    }
  }
}
